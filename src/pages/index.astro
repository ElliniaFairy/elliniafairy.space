	<section class="content-grid">
		<div class="glass-card">
			<h2>📷 {t('home.galleryCard')}</h2>
			<p>{t('home.galleryDescription').replace('{albumCount}', String(albumCount)).replace('{totalImages}', String(totalImages))}</p>
			<a href="/gallery" class="card-link">{t('home.galleryLink')}</a>
		</div>

		<div class="glass-card">
			<h2>🌟 {t('home.aboutCard')}</h2>
			<p>{t('home.aboutDescription')}</p>
			<a href="/about" class="card-link">{t('home.aboutLink')}</a>
		</div>

		<!-- <div class="glass-card">
