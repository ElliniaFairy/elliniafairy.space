---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<div class="hero-content">
					<h1 class="hero-title">✨ Welcome to My Universe</h1>
					<p class="hero-subtitle">Where dreams meet code, and ideas come alive in gentle light</p>
				</div>
			</section>

			<section class="content-grid">
				<div class="glass-card">
					<h2>📝 My Thoughts</h2>
					<p>Explore my latest blog posts where I share insights about development, design, and the beauty of creating digital experiences.</p>
					<a href="/blog" class="card-link">Read My Blog →</a>
				</div>

				<div class="glass-card">
					<h2>🌟 About Me</h2>
					<p>Discover my journey, passion for technology, and the creative process behind every project I craft.</p>
					<a href="/about" class="card-link">Learn More →</a>
				</div>

				<div class="glass-card">
					<h2>💫 Recent Work</h2>
					<p>A collection of projects that showcase my dedication to beautiful, functional, and meaningful design.</p>
					<a href="/blog" class="card-link">View Projects →</a>
				</div>
			</section>
		</main>

		<style>
			.hero {
				text-align: center;
				padding: 5rem 0;
				margin-bottom: 4rem;
			}

			.hero-content {
				max-width: 1000px;
				margin: 0 auto;
			}

			.hero-title {
				font-size: 3.5rem;
				font-weight: 700;
				margin-bottom: 1rem;
				background: linear-gradient(135deg, var(--accent-ultimate-purple), var(--accent-warm));
				-webkit-background-clip: text;
				-webkit-text-fill-color: transparent;
				background-clip: text;
				text-shadow: none;
			}

			.hero-subtitle {
				font-size: 1.2rem;
				color: var(--text-secondary);
				margin-bottom: 2rem;
				font-weight: 300;
			}


			.content-grid {
				display: grid;
				grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
				gap: 3rem;
				padding: 0;
				max-width: 100%;
				margin: 0 auto;
			}

			.glass-card {
				background: var(--glass-bg);
				backdrop-filter: blur(10px);
				border: 1px solid var(--glass-border);
				border-radius: 16px;
				padding: 2rem;
				box-shadow: var(--glass-shadow);
				transition: all 0.3s ease;
			}

			.glass-card:hover {
				transform: translateY(-5px);
				box-shadow: 0 12px 40px rgba(0, 0, 0, 0.4);
				border-color: var(--accent-glow);
			}

			.glass-card h2 {
				color: var(--text-primary);
				margin-bottom: 1rem;
				font-size: 1.5rem;
			}

			.glass-card p {
				color: var(--text-secondary);
				line-height: 1.6;
				margin-bottom: 1.5rem;
			}

			.card-link {
				color: var(--accent-glow);
				font-weight: 500;
				text-decoration: none;
				transition: all 0.3s ease;
			}

			.card-link:hover {
				color: var(--accent-warm);
				text-shadow: 0 0 10px var(--accent-warm);
			}


			@media (max-width: 768px) {
				.hero-title {
					font-size: 2.5rem;
				}
				
				.content-grid {
					grid-template-columns: 1fr;
					padding: 0 1rem;
				}
			}
		</style>
		<Footer />
	</body>
</html>
