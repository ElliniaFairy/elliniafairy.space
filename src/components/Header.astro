---
import HeaderLink from './HeaderLink.astro';
import { SITE_TITLE } from '../consts';
---

<header>
	<nav>
		<h2><a href="/">{SITE_TITLE}</a></h2>
		<div class="center-links">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/blog">Blog</HeaderLink>
		</div>
		<div class="right-links">
			<HeaderLink href="/about">About me</HeaderLink>
		</div>
		<button class="mobile-menu-btn" aria-label="Toggle mobile menu" onclick="toggleMobileMenu()">
			<span></span>
			<span></span>
			<span></span>
		</button>
	</nav>
	<div class="mobile-menu-overlay" id="mobileMenu">
		<div class="mobile-menu-content">
			<a href="/" class="mobile-menu-link">Home</a>
			<a href="/blog" class="mobile-menu-link">Blog</a>
			<a href="/about" class="mobile-menu-link">About me</a>
		</div>
	</div>
</header>
<style>
	header {
		margin: 0;
		padding: 0 1.5em;
		background: rgba(255, 255, 255, 0.12);
		backdrop-filter: blur(25px) saturate(200%);
		border-bottom: 1px solid rgba(255, 255, 255, 0.25);
		border-top: 1px solid rgba(255, 255, 255, 0.15);
		box-shadow: 
			0 20px 60px rgba(0, 0, 0, 0.3),
			0 8px 16px rgba(0, 0, 0, 0.15),
			0 0 0 1px rgba(255, 255, 255, 0.2),
			inset 0 2px 0 rgba(255, 255, 255, 0.4),
			inset 0 -2px 0 rgba(255, 255, 255, 0.1),
			0 0 40px rgba(34, 211, 238, 0.3),
			0 0 80px rgba(139, 92, 246, 0.2);
		position: relative;
		overflow: hidden;
		transform: perspective(1000px) rotateX(1deg);
	}
	
	header::before {
		content: '';
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		bottom: 0;
		background: linear-gradient(135deg, 
			rgba(255, 255, 255, 0.15) 0%, 
			rgba(255, 255, 255, 0.08) 30%,
			rgba(255, 255, 255, 0.03) 70%, 
			rgba(255, 255, 255, 0.12) 100%);
		pointer-events: none;
		z-index: -1;
	}
	h2 {
		margin: 0;
		font-size: 1.2em;
		font-weight: 700;
		font-family: 'Montserrat', sans-serif;
	}

	h2 a,
	h2 a.active {
		text-decoration: none;
		color: var(--text-primary);
		text-shadow: var(--text-glow);
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 1rem 0;
	}
	.center-links {
		position: absolute;
		left: 50%;
		transform: translateX(-50%);
		display: flex;
		gap: 0;
	}
	.right-links {
		display: flex;
	}
	nav a {
		padding: 0.6em 1em;
		color: var(--text-secondary);
		border-bottom: 2px solid transparent;
		margin-bottom: -2px;
		text-decoration: none;
		transition: all 0.3s ease;
		border-radius: 8px;
		font-family: 'Montserrat', sans-serif;
		font-weight: 600;
	}
	nav a:hover {
		color: var(--accent-glow);
		text-shadow: 0 0 10px var(--accent-glow);
		background: rgba(100, 181, 246, 0.1);
	}
	nav a.active {
		color: var(--accent-warm);
		border-bottom-color: var(--accent-warm);
		text-shadow: 0 0 12px var(--accent-warm);
	}
	.mobile-menu-btn {
		display: none;
		flex-direction: column;
		background: none;
		border: none;
		cursor: pointer;
		padding: 0.5em;
		gap: 4px;
	}
	
	.mobile-menu-btn span {
		display: block;
		width: 25px;
		height: 3px;
		background: var(--text-secondary);
		border-radius: 2px;
		transition: all 0.3s ease;
	}
	
	.mobile-menu-btn:hover span {
		background: var(--accent-glow);
		box-shadow: 0 0 8px var(--accent-glow);
	}
	
	.mobile-menu-overlay {
		display: none;
		position: fixed;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		background: rgba(0, 0, 0, 0.9);
		backdrop-filter: blur(10px);
		z-index: 1000;
		opacity: 0;
		transition: opacity 0.3s ease;
	}
	
	.mobile-menu-overlay.active {
		display: flex;
		opacity: 1;
		align-items: center;
		justify-content: center;
	}
	
	.mobile-menu-content {
		display: flex;
		flex-direction: column;
		gap: 2rem;
		text-align: center;
	}
	
	.mobile-menu-link {
		color: var(--text-primary);
		text-decoration: none;
		font-size: 2rem;
		font-weight: 600;
		font-family: 'Montserrat', sans-serif;
		text-shadow: var(--text-glow);
		transition: all 0.3s ease;
		padding: 1rem;
		border-radius: 12px;
	}
	
	.mobile-menu-link:hover {
		color: var(--accent-glow);
		text-shadow: 0 0 20px var(--accent-glow);
		background: rgba(100, 181, 246, 0.1);
		transform: scale(1.05);
	}
	
	@media (max-width: 720px) {
		header {
			padding: 0 1em;
		}
		
		.center-links,
		.right-links {
			display: none;
		}
		
		.mobile-menu-btn {
			display: flex;
		}
	}
</style>

<script is:inline>
	window.toggleMobileMenu = function() {
		const mobileMenu = document.getElementById('mobileMenu');
		mobileMenu.classList.toggle('active');
	}
	
	// Initialize when DOM is loaded
	document.addEventListener('DOMContentLoaded', function() {
		// Close mobile menu when clicking outside
		document.addEventListener('click', (e) => {
			const mobileMenu = document.getElementById('mobileMenu');
			const menuBtn = document.querySelector('.mobile-menu-btn');
			
			if (mobileMenu && mobileMenu.classList.contains('active')) {
				if (e.target === mobileMenu || (!menuBtn.contains(e.target) && !mobileMenu.querySelector('.mobile-menu-content').contains(e.target))) {
					mobileMenu.classList.remove('active');
				}
			}
		});
		
		// Close mobile menu on escape key
		document.addEventListener('keydown', (e) => {
			if (e.key === 'Escape') {
				const mobileMenu = document.getElementById('mobileMenu');
				if (mobileMenu && mobileMenu.classList.contains('active')) {
					mobileMenu.classList.remove('active');
				}
			}
		});
	});
</script>
