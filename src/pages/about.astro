---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import avatar from '../assets/avatar/avatar.png';

---

<BaseLayout title="About - Ellinia Fairy" description="Learn about Ellinia Fairy - a mathematics graduate turned app developer, exploring the intersection of intelligence and aesthetics through technology and creativity." showFooter={false}>
	<div class="hero-content">
		<div class="hero-text">
			<h1 class="hero-title">
				🍃 About Me
			</h1>
			<div class="hero-intro">
				<p>I'm <strong>Ellinia Fairy</strong>—a mathematics graduate turned app developer. I currently work in <strong>Yokohama Minato Mirai 21</strong>, a futuristic district, and live in <strong>Tokyo Haneda</strong>, close to the open skies inspiring my creative spirit.</p>
				<p>I build with logic, but I live for resonance. Technology alone doesn't fascinate me; what deeply resonates are the stories born from technological possibilities and human creativity. I explore the intersection of intelligence and aesthetics through meteorology, storytelling and photography, aiming to blend rigorous science with artistic expression.</p>
			</div>
			<div class="action-section">
				<a href="/about-me" class="find-more-btn">
					<span class="btn-text">Find out more about me</span>
					<svg width="16" height="16" viewBox="0 0 24 24" fill="none">
						<path d="M7 17L17 7M17 7H7M17 7V17" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
					</svg>
				</a>
				<div class="social-links">
				<a href="https://space.bilibili.com/3981688" target="_blank" class="social-link">
					<span class="sr-only">Visit my Bilibili</span>
					<svg viewBox="0 0 24 24" aria-hidden="true" width="32" height="32">
						<path fill="currentColor" d="M17.813 4.653h.854c1.51.054 2.769.578 3.773 1.574 1.004.995 1.524 2.249 1.56 3.76v7.36c-.036 1.51-.556 2.769-1.56 3.773s-2.262 1.524-3.773 1.56H5.333c-1.51-.036-2.769-.556-3.773-1.56S.036 18.858 0 17.347v-7.36c.036-1.511.556-2.765 1.56-3.76 1.004-.996 2.262-1.52 3.773-1.574h.774l-1.174-1.12a1.234 1.234 0 0 1-.373-.906c0-.356.124-.658.373-.907l.027-.027c.267-.249.573-.373.92-.373.347 0 .653.124.92.373L9.653 4.44c.071.071.134.142.187.213h4.267a.836.836 0 0 1 .16-.213l2.853-2.747c.267-.249.573-.373.92-.373.347 0 .662.151.929.4.267.249.391.551.391.907 0 .356-.124.657-.373.906zM5.333 7.24c-.746.018-1.373.276-1.88.773-.506.498-.769 1.13-.786 1.894v7.52c.017.764.28 1.395.786 1.893.507.498 1.134.756 1.88.773h13.334c.746-.017 1.373-.275 1.88-.773.506-.498.769-1.129.786-1.893v-7.52c-.017-.765-.28-1.396-.786-1.894-.507-.497-1.134-.755-1.88-.773zM8 11.107c.373 0 .684.124.933.373.249.249.384.569.384.96v1.173c0 .391-.135.711-.384.96-.249.249-.56.374-.933.374s-.684-.125-.933-.374c-.249-.249-.384-.569-.384-.96V12.44c0-.391.135-.711.384-.96.249-.249.56-.373.933-.373zm8 0c.373 0 .684.124.933.373.249.249.384.569.384.96v1.173c0 .391-.135.711-.384.96-.249.249-.56.374-.933.374s-.684-.125-.933-.374c-.249-.249-.384-.569-.384-.96V12.44c0-.391.135-.711.384-.96.249-.249.56-.373.933-.373z"></path>
					</svg>
				</a>
				<a href="https://weibo.com/u/1666486042" target="_blank" class="social-link">
					<span class="sr-only">Follow me on Weibo</span>
					<svg viewBox="0 0 512 415" aria-hidden="true" width="32" height="32" fill-rule="evenodd" clip-rule="evenodd" stroke-linejoin="round" stroke-miterlimit="2">
						<g transform="scale(1.45729)">
							<clipPath id="prefix__a">
								<path d="M0 0h351.336v284.628H0z"></path>
							</clipPath>
							<g clip-path="url(#prefix__a)" fill-rule="nonzero">
								<path d="M25.84 195.715c0 40.917 53.28 74.078 118.97 74.078 65.691 0 118.971-33.161 118.971-74.078 0-40.918-53.28-74.078-118.971-74.078-65.69 0-118.97 33.16-118.97 74.078" fill="var(--primary-navy)"></path>
								<path d="M147.622 263.781c-58.176 5.769-108.401-20.556-112.183-58.71-3.781-38.202 40.336-73.786 98.463-79.556 58.177-5.769 108.402 20.556 112.135 58.71 3.83 38.202-40.287 73.835-98.415 79.556m116.304-126.776c-4.945-1.503-8.338-2.472-5.769-8.969 5.624-14.107 6.206-26.276.097-35.002-11.393-16.29-42.614-15.417-78.392-.437 0 0-11.248 4.897-8.339-3.975 5.478-17.695 4.654-32.482-3.878-41.063-19.392-19.44-71.024.727-115.286 44.99C19.247 125.661 0 160.809 0 191.206c0 58.079 74.514 93.422 147.38 93.422 95.555 0 159.112-55.51 159.112-99.579.049-26.664-22.398-41.79-42.566-48.044" fill="currentColor"></path>
