---
import MainLayout from '../layouts/MainLayout.astro';
import GalleryCard from '../components/GalleryCard.astro';
import { SITE_TITLE } from '../consts';
import { getCollection } from 'astro:content';
import { resolveLanguage, useTranslations } from '../utils/language';

export const prerender = false;

const language = resolveLanguage(
  Astro.url.searchParams.get('lang'),
  Astro.cookies.get('language')?.value,
);

const t = useTranslations(language);

const albums = (await getCollection('gallery'))
  .filter(album => album.data.language === language)
  .sort(
    (a, b) => new Date(b.data.publishDate).valueOf() - new Date(a.data.publishDate).valueOf(),
  );
---

<MainLayout title={`Gallery - ${SITE_TITLE}`} description="Explore my photo albums and memories" glowing={true}>
	<section class="hero">
		<div class="hero-content">
			<h1 class="hero-title"><span class="emoji">📷</span> {t('gallery.title')}</h1>
			<p class="hero-subtitle">{t('gallery.description')}</p>
		</div>
	</section>

	<section class="gallery-grid">
		{albums.map((album) => (
			<div
				class="gallery-item"
				data-language={album.data.language}
			>
				<GalleryCard
					title={album.data.title}
					description={album.data.description}
					coverImage={album.data.coverImage}
					imageCount={album.data.images.length}
					href={`/galleries/${album.id}`}
					language={language}
				/>
			</div>
		))}
	</section>

	{language === 'en' && (
		<div class="other-language-hint">
			<span class="hint-icon">🌏</span>
			<p>Want to see more? Switch to <strong>Chinese</strong> or <strong>Japanese</strong> for additional albums!</p>
		</div>
	)}
</MainLayout>

<style>
	.other-language-hint {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 0.75rem;
		max-width: 600px;
		margin: 3rem auto 2rem auto;
		padding: 1rem 1.5rem;
		background: var(--glass-bg);
		backdrop-filter: blur(20px);
		border: 1px solid var(--glass-border);
		border-radius: 15px;
		box-shadow: var(--glass-shadow);
	}

	.other-language-hint .hint-icon {
		font-size: 1.5rem;
		flex-shrink: 0;
	}

	.other-language-hint p {
		margin: 0;
		color: var(--text-secondary);
		font-size: 0.95rem;
		line-height: 1.5;
	}

	.other-language-hint strong {
		color: var(--accent);
	}

	.hero {
		text-align: center;
		padding: 4rem 0 2rem 0;
		margin-bottom: 3rem;
	}

	.hero-content {
		max-width: 800px;
		margin: 0 auto;
	}

	.hero-title {
		font-size: 3.5rem;
		font-weight: 700;
		margin-bottom: 1rem;
		background: linear-gradient(135deg, var(--text-primary), var(--accent-glow));
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
		text-shadow: none;
	}

	/* Prevent emoji from being rendered by gradient */
	.hero-title .emoji {
		-webkit-background-clip: initial;
		-webkit-text-fill-color: initial;
		background-clip: initial;
		color: initial;
	}

	.hero-subtitle {
		font-size: 1.1rem;
		color: var(--text-secondary);
		margin-bottom: 1rem;
		font-weight: 400;
	}

	.gallery-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
		gap: 2rem;
		max-width: 1400px;
		margin: 0 auto;
		padding: 0 2rem;
	}

	@media (max-width: 768px) {
		.hero-title {
			font-size: 2.5rem;
		}

		.gallery-grid {
			grid-template-columns: 1fr;
			padding: 0 1rem;
			gap: 1.5rem;
		}
	}

	@media (max-width: 480px) {
		.hero {
			padding: 3rem 0 2rem 0;
		}

		.hero-title {
			font-size: 2rem;
		}

		.hero-subtitle {
			font-size: 1rem;
		}
	}
</style>

<script>
	import { getCurrentLanguage } from '../utils/language';

	document.addEventListener('DOMContentLoaded', () => {
		const currentLanguage = getCurrentLanguage();

		const applyLanguageFilter = () => {
			const galleryItems = document.querySelectorAll('.gallery-item') as NodeListOf<HTMLElement>;
			galleryItems.forEach((item) => {
				const languageMatch = item.dataset.language === currentLanguage;
				item.style.display = languageMatch ? 'block' : 'none';
			});
		};

		applyLanguageFilter();
	});
</script>
