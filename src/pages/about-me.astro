---
import BlogLayout from '../layouts/BlogLayout.astro';
import { Content as AboutContent } from '../content/about.md';


// Create a mock blog post object for the about page
const aboutPost = {
	data: {
		title: "My Journey in Tech & Creativity",
		description: "Discover the story behind Ellinia Fairy - from mathematics to app development, exploring the intersection of logic and creativity.",
		publishDate: "2025-07-01",
		classification: "Personal Journey",
		readingTime: "13 min read",
		tags: ["Personal", "Mathematics", "Technology", "Creativity"]
	}
};

// No need to call render; use imported component directly.
---

<BlogLayout post={aboutPost}>
	<AboutContent />
</BlogLayout>