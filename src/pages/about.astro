---
import BaseLayout from '../layouts/BaseLayout.astro';

const aboutContent = await Astro.glob('./about.md');
const { Content } = aboutContent[0];
---

<BaseLayout title="About - Ellinia Fairy" description="Learn about Ellinia Fairy - a mathematics graduate turned app developer, exploring the intersection of intelligence and aesthetics through technology and creativity.">
	<section class="hero-section">
		<div class="hero-content">
			<div class="hero-text">
				<h1 class="hero-title">
					🍃 About Me
				</h1>
				<div class="hero-intro">
					<p>I'm <strong>Ellinia Fairy</strong>—a mathematics graduate turned app developer. I currently work in <strong>Yokohama Minato Mirai 21</strong>, a futuristic district, and live in <strong>Tokyo Haneda</strong>, close to the open skies inspiring my creative spirit.</p>
					<p>I build with logic, but I live for resonance. Technology alone doesn't fascinate me; what deeply resonates are the stories born from technological possibilities and human creativity. I explore the intersection of intelligence and aesthetics through meteorology, storytelling and photography, aiming to blend rigorous science with artistic expression.</p>
				</div>
				<a href="/about-me" class="find-more-btn">
					<span class="btn-text">Find out more about me</span>
					<svg width="16" height="16" viewBox="0 0 24 24" fill="none">
						<path d="M7 17L17 7M17 7H7M17 7V17" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
					</svg>
				</a>
			</div>
			<div class="hero-visual">
				<div class="avatar-container">
					<div class="eclipse-effect"></div>
					<img src="/src/assets/avatar/avatar.png" alt="Ellinia Fairy" class="avatar-image" />
				</div>
				<div class="map-container">
					<iframe 
						src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d414604.2754293876!2d139.75446034853152!3d35.54828459292251!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zMzXCsDMyJzUzLjgiTiAxMznCsDQ1JzE2LjEiRQ!5e0!3m2!1sen!2sjp!4v1"
						class="google-map"
						allowfullscreen=""
						loading="lazy"
						referrerpolicy="no-referrer-when-downgrade">
					</iframe>
				</div>
			</div>
		</div>
	</section>
</BaseLayout>

<style>
/* Hero Section */
.hero-section {
	width: 100vw;
	height: 70vh;
	background: linear-gradient(135deg, 
		rgba(13, 25, 43, 0.95) 0%,
		rgba(25, 39, 67, 0.9) 50%,
		rgba(13, 25, 43, 0.95) 100%
	);
	position: relative;
	overflow: hidden;
	display: flex;
	align-items: center;
	justify-content: center;
	padding: 0;
	margin-left: calc(-50vw + 50%);
	margin-right: calc(-50vw + 50%);
}

.hero-section::before {
	content: '';
	position: absolute;
	top: 0;
	left: 0;
	right: 0;
	bottom: 0;
	background: 
		radial-gradient(circle at 20% 30%, rgba(0, 255, 255, 0.1) 0%, transparent 50%),
		radial-gradient(circle at 80% 70%, rgba(255, 0, 255, 0.1) 0%, transparent 50%),
		radial-gradient(circle at 50% 50%, rgba(138, 43, 226, 0.05) 0%, transparent 70%);
	animation: backgroundPulse 8s ease-in-out infinite;
}

.hero-content {
	display: grid;
	grid-template-columns: 1fr 1fr;
	gap: 4rem;
	max-width: 70vw;
	width: 100%;
	padding: 0 2rem;
	z-index: 2;
	position: relative;
	align-items: center;
}

.hero-text {
	padding: 2rem 0;
}

.hero-title {
	font-family: 'Sora', sans-serif;
	font-size: clamp(2rem, 4vw, 3.5rem);
	font-weight: 800;
	line-height: 1.1;
	margin-bottom: 1.5rem;
	color: var(--text-primary);
}

.sparkle {
	display: inline-block;
	animation: sparkleRotate 3s ease-in-out infinite;
	filter: none;
}

.hero-intro {
	font-family: 'Inter', sans-serif;
	font-size: 1.1rem;
	line-height: 1.7;
	color: var(--text-secondary);
	margin-top: 1.5rem;
}

.hero-intro p {
	margin-bottom: 1.2rem;
}

.hero-intro strong {
	color: var(--text-primary);
	font-weight: 600;
}

.find-more-btn {
	display: inline-flex;
	align-items: center;
	gap: 0.5rem;
	background: linear-gradient(135deg, var(--accent) 0%, var(--accent-glow) 100%);
	color: white;
	padding: 1.2rem 2.5rem;
	border-radius: 30px;
	text-decoration: none;
	font-weight: 600;
	font-size: 1.1rem;
	font-family: 'Montserrat', sans-serif;
	transition: all 0.3s ease;
	box-shadow: 
		0 8px 20px rgba(41, 98, 255, 0.3),
		0 0 0 1px rgba(255, 255, 255, 0.1);
	position: relative;
	overflow: hidden;
	margin-top: 2rem;
}

.find-more-btn:hover {
	transform: translateY(-2px);
	box-shadow: 
		0 12px 30px rgba(41, 98, 255, 0.4),
		0 0 40px rgba(34, 211, 238, 0.3);
}

.find-more-btn svg {
	transition: transform 0.3s ease;
}

.find-more-btn:hover svg {
	transform: translate(2px, -2px);
}

.hero-visual {
	position: relative;
	height: 100%;
	display: flex;
	align-items: center;
	justify-content: center;
	gap: 4rem;
}

.avatar-container {
	position: relative;
	width: 320px;
	height: 320px;
	display: flex;
	align-items: center;
	justify-content: center;
}

.eclipse-effect {
	position: absolute;
	width: 100%;
	height: 100%;
	border-radius: 50%;
	background: radial-gradient(circle at 30% 30%, 
		rgba(0, 255, 255, 0.4) 0%,
		rgba(138, 43, 226, 0.3) 40%,
		rgba(255, 0, 255, 0.2) 70%,
		transparent 100%
	);
	animation: eclipsePulse 4s ease-in-out infinite;
	z-index: 1;
}

.eclipse-effect::before {
	content: '';
	position: absolute;
	top: -10px;
	left: -10px;
	right: -10px;
	bottom: -10px;
	border-radius: 50%;
	background: linear-gradient(45deg, 
		rgba(0, 255, 255, 0.1) 0%,
		transparent 30%,
		transparent 70%,
		rgba(255, 0, 255, 0.1) 100%
	);
	animation: eclipseRotate 6s linear infinite;
}

.avatar-image {
	width: 280px;
	height: 280px;
	border-radius: 50%;
	object-fit: cover;
	border: 3px solid rgba(255, 255, 255, 0.1);
	box-shadow: 
		0 0 30px rgba(0, 255, 255, 0.3),
		0 0 60px rgba(138, 43, 226, 0.2),
		inset 0 0 30px rgba(255, 255, 255, 0.05);
	z-index: 2;
	position: relative;
	transition: transform 0.3s ease;
}

.avatar-image:hover {
	transform: scale(1.05);
}

.map-container {
	position: relative;
	width: 280px;
	height: 280px;
	border-radius: 50%;
	overflow: hidden;
	border: 3px solid rgba(255, 255, 255, 0.1);
	box-shadow: 
		0 0 30px rgba(34, 197, 94, 0.4),
		0 0 60px rgba(22, 163, 74, 0.3),
		0 0 90px rgba(16, 185, 129, 0.2),
		inset 0 0 30px rgba(134, 239, 172, 0.05);
	transition: transform 0.3s ease;
}

.map-container:hover {
	transform: scale(1.05);
}



.google-map {
	width: 100%;
	height: 100%;
	border: none;
	filter: contrast(1.1) brightness(0.9) hue-rotate(15deg);
}

@keyframes backgroundPulse {
	0%, 100% { opacity: 1; }
	50% { opacity: 0.8; }
}

@keyframes sparkleRotate {
	0%, 100% { transform: rotate(0deg) scale(1); }
	25% { transform: rotate(90deg) scale(1.1); }
	50% { transform: rotate(180deg) scale(1); }
	75% { transform: rotate(270deg) scale(1.1); }
}

@keyframes orbPulse {
	0%, 100% { 
		transform: scale(1);
		opacity: 0.8;
	}
	50% { 
		transform: scale(1.1);
		opacity: 1;
	}
}

@keyframes innerGlow {
	0%, 100% { 
		transform: translate(-50%, -50%) scale(1);
		opacity: 0.3;
	}
	50% { 
		transform: translate(-50%, -50%) scale(1.2);
		opacity: 0.6;
	}
}

@keyframes float {
	0%, 100% { 
		transform: translateY(0px) rotate(0deg);
		opacity: 0.8;
	}
	25% { 
		transform: translateY(-20px) rotate(90deg);
		opacity: 1;
	}
	50% { 
		transform: translateY(-10px) rotate(180deg);
		opacity: 0.6;
	}
	75% { 
		transform: translateY(-15px) rotate(270deg);
		opacity: 1;
	}
}

@media (max-width: 768px) {
	.hero-content {
		grid-template-columns: 1fr;
		gap: 2rem;
		text-align: center;
		padding: 0 1rem;
	}
	
	.hero-visual {
		height: 300px;
	}
	
	.magic-orb {
		width: 200px;
		height: 200px;
	}
	
	.magic-orb::before {
		width: 120px;
		height: 120px;
	}
	
	.element {
		font-size: 1.5rem;
	}
}


@media (max-width: 768px) {
	.hero-content {
		grid-template-columns: 1fr;
		gap: 2rem;
		text-align: center;
		padding: 0 1rem;
		max-width: 90vw;
	}
	
	.hero-section {
		height: 60vh;
	}
	
	.hero-visual {
		flex-direction: row;
		gap: 1.5rem;
	}
	
	.avatar-container {
		width: 200px;
		height: 200px;
	}
	
	.avatar-image {
		width: 180px;
		height: 180px;
	}
	
	.map-container {
		width: 200px;
		height: 200px;
	}
	
}
</style>

