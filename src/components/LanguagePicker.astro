---
import { getCurrentLanguage, LANGUAGES, type Language } from '../utils/language';
const languages = Object.values(LANGUAGES);

const urlLang = Astro.url.searchParams.get('lang');
const current = urlLang && LANGUAGES[urlLang as Language]
  ? (urlLang as Language)
  : getCurrentLanguage();
---
<div class="language-picker">
	<button class="trigger" type="button" aria-haspopup="listbox" aria-expanded="false">
		<span class="flag" aria-hidden="true">{LANGUAGES[current].flag}</span>
		<span class="code">{LANGUAGES[current].name}</span>
		<span class="chevron" aria-hidden="true">v</span>
	</button>
	<div class="menu" role="listbox">
		{languages.map((lang) => (
			<button
				class="option"
				type="button"
				role="option"
				data-lang={lang.code}
				aria-selected={lang.code === current}
			>
				<span class="flag" aria-hidden="true">{lang.flag}</span>
				<span class="name">{lang.name}</span>
				<span class="code">{lang.code}</span>
			</button>
		))}
	</div>
</div>
<style>
	.language-picker {
		position: relative;
		display: flex;
	}
	.trigger {
		display: flex; 
		align-items: center; 
		gap: 0.5rem; 
		background: rgba(20,20,30,0.8); 
		color: var(--text-secondary); 
		border: 1px solid rgba(255,255,255,0.25); 
		border-radius: 999px; 
		padding: 0.35rem 0.75rem; 
		font: 600 0.85rem 'Montserrat', sans-serif; 
		cursor: pointer; 
		box-shadow: 0 10px 30px rgba(0,0,0,0.35), 0 0 0 2px rgba(255,255,255,0.08), 0 0 20px rgba(126, 34, 238, 0.25); 
		transition: all 0.25s ease; 
	}
	.trigger:hover, .language-picker:focus-within .trigger {
		color: var(--accent-glow); 
		text-shadow: 0 0 8px var(--accent-glow); 
		border-color: rgba(94,234,212,0.6); 
	}
	.menu {
		position: absolute; 
		right: 0; 
		top: calc(100% + 0.55rem); 
		display: flex; 
		flex-direction: column; 
		gap: 0.35rem; 
		min-width: 190px; 
		padding: 0.5rem; 
		background: rgba(14,14,24,0.96); 
		border: 1px solid rgba(255,255,255,0.12); 
		border-radius: 14px; 
		box-shadow: 0 20px 50px rgba(0,0,0,0.35), 0 0 0 1px rgba(255,255,255,0.08); 
		opacity: 0; 
		visibility: hidden; 
		transform: translateY(-8px); 
		transition: all 0.25s ease; 
		z-index: 3; 
	}
	.language-picker:hover .menu, .language-picker:focus-within .menu {
		opacity: 1; 
		visibility: visible; 
		transform: translateY(0); 
	}
	.option {
		display: flex; 
		align-items: center; 
		justify-content: space-between; 
		gap: 0.6rem; 
		padding: 0.5rem 0.65rem; 
		background: transparent; 
		border: none; 
		border-radius: 10px; 
		color: rgba(255,255,255,0.85); 
		font: 600 0.85rem 'Montserrat', sans-serif; 
		cursor: pointer; 
		transition: all 0.25s ease; 
	}
	.option:hover, .option:focus {
		color: var(--accent-glow); 
		background: rgba(94,234,212,0.08); 
		text-shadow: 0 0 10px rgba(94,234,212,0.6); 
	}
	.name {
		flex: 1; 
		text-align: left; 
	}
	.code {
		letter-spacing: 0.08em; 
		text-transform: uppercase; 
	}
	.chevron { font-size: 0.75rem; }
</style>

<script>
	import { getCurrentLanguage, LANGUAGES, type Language, setLanguage } from '../utils/language';
	document.querySelectorAll('.language-picker').forEach((picker) => {
		const triggerFlag = picker.querySelector('.trigger .flag');
		const triggerLabel = picker.querySelector('.trigger .code');
		const optionButtons = Array.from(picker.querySelectorAll('button[data-lang]'));


		const applyLanguage = (lang: Language) => {
			const config = LANGUAGES[lang];
			if (!config) {
				return;
			}
			if (triggerFlag) {
				triggerFlag.textContent = config.flag;
			}
			if (triggerLabel) {
				triggerLabel.textContent = config.name;
			}
			optionButtons.forEach((btn) => {
				const isActive = btn.getAttribute('data-lang') === lang;
				btn.setAttribute('aria-selected', String(isActive));
			});
		};

		applyLanguage(getCurrentLanguage());

		optionButtons.forEach((btn) => {
			btn.addEventListener('click', () => {
				const lang = btn.getAttribute('data-lang');
				if (!lang) {
					return;
				}
				if (lang !== getCurrentLanguage()) {
					setLanguage(lang as Language);
				}
			});
		});
	});
</script>
