---
import BaseLayout from '../layouts/BaseLayout.astro';

const aboutContent = await Astro.glob('./about.md');
const { Content } = aboutContent[0];
---

<BaseLayout title="About - Ellinia Fairy" description="Learn about Ellinia Fairy - a mathematics graduate turned app developer, exploring the intersection of intelligence and aesthetics through technology and creativity.">
	<section class="hero-section">
		<div class="hero-content">
			<div class="hero-text">
				<h1 class="hero-title">
					🍃 About Me
				</h1>
				<div class="hero-intro">
					<p>I'm <strong>Ellinia Fairy</strong>—a mathematics graduate turned app developer. I currently work in <strong>Yokohama Minato Mirai 21</strong>, a futuristic district, and live in <strong>Tokyo Haneda</strong>, close to the open skies inspiring my creative spirit.</p>
					<p>I build with logic, but I live for resonance. Technology alone doesn't fascinate me; what deeply resonates are the stories born from technological possibilities and human creativity. I explore the intersection of intelligence and aesthetics through meteorology, storytelling and photography, aiming to blend rigorous science with artistic expression.</p>
				</div>
			</div>
			<div class="hero-visual">
				<div class="avatar-container">
					<div class="eclipse-effect"></div>
					<img src="/src/assets/avatar/avatar.png" alt="Ellinia Fairy" class="avatar-image" />
				</div>
			</div>
		</div>
	</section>
	
	<section class="read-more-section">
		<button class="read-more-btn" onclick="toggleReadMore()">
			<span class="btn-text">Read More About My Journey</span>
			<span class="btn-icon">↓</span>
		</button>
	</section>
	
	<article class="about-content">
		<Content />
	</article>
</BaseLayout>

<style>
/* Hero Section */
.hero-section {
	width: 100vw;
	height: 500px;
	background: linear-gradient(135deg, 
		rgba(13, 25, 43, 0.95) 0%,
		rgba(25, 39, 67, 0.9) 50%,
		rgba(13, 25, 43, 0.95) 100%
	);
	position: relative;
	overflow: hidden;
	display: flex;
	align-items: center;
	justify-content: center;
	padding: 0;
	margin-left: calc(-50vw + 50%);
	margin-right: calc(-50vw + 50%);
}

.hero-section::before {
	content: '';
	position: absolute;
	top: 0;
	left: 0;
	right: 0;
	bottom: 0;
	background: 
		radial-gradient(circle at 20% 30%, rgba(0, 255, 255, 0.1) 0%, transparent 50%),
		radial-gradient(circle at 80% 70%, rgba(255, 0, 255, 0.1) 0%, transparent 50%),
		radial-gradient(circle at 50% 50%, rgba(138, 43, 226, 0.05) 0%, transparent 70%);
	animation: backgroundPulse 8s ease-in-out infinite;
}

.hero-content {
	display: grid;
	grid-template-columns: 1fr 1fr;
	gap: 4rem;
	max-width: 1400px;
	width: 100%;
	padding: 0 2rem;
	z-index: 2;
	position: relative;
	align-items: center;
}

.hero-text {
	padding: 2rem 0;
}

.hero-title {
	font-family: 'Sora', sans-serif;
	font-size: clamp(2rem, 4vw, 3.5rem);
	font-weight: 800;
	line-height: 1.1;
	margin-bottom: 1.5rem;
	color: var(--text-primary);
}

.sparkle {
	display: inline-block;
	animation: sparkleRotate 3s ease-in-out infinite;
	filter: none;
}

.hero-intro {
	font-family: 'Inter', sans-serif;
	font-size: 1.1rem;
	line-height: 1.7;
	color: var(--text-secondary);
	margin-top: 1.5rem;
}

.hero-intro p {
	margin-bottom: 1.2rem;
}

.hero-intro strong {
	color: var(--text-primary);
	font-weight: 600;
}

.hero-visual {
	position: relative;
	height: 100%;
	display: flex;
	align-items: center;
	justify-content: center;
}

.avatar-container {
	position: relative;
	width: 320px;
	height: 320px;
	display: flex;
	align-items: center;
	justify-content: center;
}

.eclipse-effect {
	position: absolute;
	width: 100%;
	height: 100%;
	border-radius: 50%;
	background: radial-gradient(circle at 30% 30%, 
		rgba(0, 255, 255, 0.4) 0%,
		rgba(138, 43, 226, 0.3) 40%,
		rgba(255, 0, 255, 0.2) 70%,
		transparent 100%
	);
	animation: eclipsePulse 4s ease-in-out infinite;
	z-index: 1;
}

.eclipse-effect::before {
	content: '';
	position: absolute;
	top: -10px;
	left: -10px;
	right: -10px;
	bottom: -10px;
	border-radius: 50%;
	background: linear-gradient(45deg, 
		rgba(0, 255, 255, 0.1) 0%,
		transparent 30%,
		transparent 70%,
		rgba(255, 0, 255, 0.1) 100%
	);
	animation: eclipseRotate 6s linear infinite;
}

.avatar-image {
	width: 280px;
	height: 280px;
	border-radius: 50%;
	object-fit: cover;
	border: 3px solid rgba(255, 255, 255, 0.1);
	box-shadow: 
		0 0 30px rgba(0, 255, 255, 0.3),
		0 0 60px rgba(138, 43, 226, 0.2),
		inset 0 0 30px rgba(255, 255, 255, 0.05);
	z-index: 2;
	position: relative;
	transition: transform 0.3s ease;
}

.avatar-image:hover {
	transform: scale(1.05);
}

@keyframes backgroundPulse {
	0%, 100% { opacity: 1; }
	50% { opacity: 0.8; }
}

@keyframes sparkleRotate {
	0%, 100% { transform: rotate(0deg) scale(1); }
	25% { transform: rotate(90deg) scale(1.1); }
	50% { transform: rotate(180deg) scale(1); }
	75% { transform: rotate(270deg) scale(1.1); }
}

@keyframes orbPulse {
	0%, 100% { 
		transform: scale(1);
		opacity: 0.8;
	}
	50% { 
		transform: scale(1.1);
		opacity: 1;
	}
}

@keyframes innerGlow {
	0%, 100% { 
		transform: translate(-50%, -50%) scale(1);
		opacity: 0.3;
	}
	50% { 
		transform: translate(-50%, -50%) scale(1.2);
		opacity: 0.6;
	}
}

@keyframes float {
	0%, 100% { 
		transform: translateY(0px) rotate(0deg);
		opacity: 0.8;
	}
	25% { 
		transform: translateY(-20px) rotate(90deg);
		opacity: 1;
	}
	50% { 
		transform: translateY(-10px) rotate(180deg);
		opacity: 0.6;
	}
	75% { 
		transform: translateY(-15px) rotate(270deg);
		opacity: 1;
	}
}

@media (max-width: 768px) {
	.hero-content {
		grid-template-columns: 1fr;
		gap: 2rem;
		text-align: center;
		padding: 0 1rem;
	}
	
	.hero-visual {
		height: 300px;
	}
	
	.magic-orb {
		width: 200px;
		height: 200px;
	}
	
	.magic-orb::before {
		width: 120px;
		height: 120px;
	}
	
	.element {
		font-size: 1.5rem;
	}
}

.container {
	max-width: 1200px;
	margin: 0 auto;
	padding: 2rem 1rem;
}

.about-content {
	background: rgba(255, 255, 255, 0.05);
	backdrop-filter: blur(10px);
	border: 1px solid rgba(255, 255, 255, 0.1);
	border-radius: 20px;
	padding: 3rem;
	box-shadow: 
		0 8px 32px rgba(0, 0, 0, 0.2),
		inset 0 1px 0 rgba(255, 255, 255, 0.1);
	margin: 2rem 0;
}

.about-content :global(h1) {
	font-family: 'Sora', sans-serif;
	font-size: 2.5rem;
	font-weight: 700;
	color: var(--text-primary);
	margin-bottom: 1.5rem;
	text-align: center;
	background: linear-gradient(135deg, var(--accent-cyan), var(--accent-pink));
	-webkit-background-clip: text;
	-webkit-text-fill-color: transparent;
	background-clip: text;
}

.about-content :global(h2) {
	font-family: 'Sora', sans-serif;
	font-size: 1.8rem;
	font-weight: 600;
	color: var(--accent-cyan);
	margin: 2.5rem 0 1rem 0;
	border-bottom: 2px solid var(--accent-cyan);
	padding-bottom: 0.5rem;
}

.about-content :global(h3) {
	font-family: 'Sora', sans-serif;
	font-size: 1.4rem;
	font-weight: 600;
	color: var(--accent-pink);
	margin: 2rem 0 1rem 0;
}

.about-content :global(p) {
	font-family: 'Inter', sans-serif;
	font-size: 1.1rem;
	line-height: 1.8;
	color: var(--text-secondary);
	margin-bottom: 1.5rem;
}

.about-content :global(strong) {
	color: var(--text-primary);
	font-weight: 600;
}

.about-content :global(ul) {
	margin: 1rem 0 1.5rem 1rem;
}

.about-content :global(li) {
	font-family: 'Inter', sans-serif;
	font-size: 1.1rem;
	line-height: 1.7;
	color: var(--text-secondary);
	margin-bottom: 0.5rem;
	list-style-type: none;
	position: relative;
	padding-left: 1.5rem;
}

.about-content :global(li::before) {
	content: '✨';
	position: absolute;
	left: 0;
	color: var(--accent-cyan);
}

.about-content :global(table) {
	width: 100%;
	border-collapse: separate;
	border-spacing: 0;
	margin: 2rem 0;
	background: rgba(255, 255, 255, 0.03);
	border-radius: 12px;
	overflow: hidden;
	border: 1px solid rgba(255, 255, 255, 0.1);
}

.about-content :global(th) {
	background: rgba(var(--accent-cyan-rgb), 0.2);
	color: var(--text-primary);
	font-family: 'Sora', sans-serif;
	font-weight: 600;
	padding: 1rem;
	text-align: left;
	border-bottom: 1px solid rgba(255, 255, 255, 0.1);
}

.about-content :global(td) {
	padding: 1rem;
	color: var(--text-secondary);
	border-bottom: 1px solid rgba(255, 255, 255, 0.05);
}

.about-content :global(tr:last-child td) {
	border-bottom: none;
}

.about-content :global(code) {
	font-family: 'JetBrains Mono', monospace;
	background: rgba(var(--accent-purple-rgb), 0.2);
	padding: 0.2rem 0.4rem;
	border-radius: 4px;
	font-size: 0.9rem;
	color: var(--accent-purple);
}

@media (max-width: 768px) {
	.container {
		padding: 1rem 0.5rem;
	}
	
	.about-content {
		padding: 2rem;
		margin: 1rem 0;
	}
	
	.about-content :global(h1) {
		font-size: 2rem;
	}
	
	.about-content :global(h2) {
		font-size: 1.5rem;
	}
	
	.about-content :global(table) {
		font-size: 0.9rem;
	}
	
	.about-content :global(th),
	.about-content :global(td) {
		padding: 0.7rem;
	}
}
</style>