---
import MainLayout from "./MainLayout.astro";
import TableOfContents from "../components/TableOfContents.astro";
import type { CollectionEntry } from "astro:content";

export type BlogPost = CollectionEntry<'blog'>;
const { post } = Astro.props as { post: BlogPost };
const language = post.data.language ?? 'en';

// Format date for better display
const formatDate = (date: string) => {
  return new Intl.DateTimeFormat('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric'
  }).format(new Date(date));
};

---

<MainLayout
  title={post.data.title}
  description={post.data.description}
  image={post.data.image}
>
  <div class="blog-container">
    <div class="reading-progress" id="reading-progress"></div>
    
    <!-- Table of Contents -->
    <TableOfContents />
    
    <article class="blog-post">
      <header class="blog-header">
        <div class="blog-header-content">
          {post.data.classification && (
            <div class="classification-tag">
              {post.data.classification}
            </div>
          )}
          <h1 class="blog-title">{post.data.title}</h1>
          <div class="blog-meta">
            <div class="meta-item">
              📅 <time class="publish-date" datetime={post.data.publishDate}>
                {formatDate(post.data.publishDate)}
              </time>
            </div>
            {post.data.readingTime && (
              <div class="meta-item">
                ⏱️ <span class="reading-time">{post.data.readingTime}</span>
              </div>
            )}
          </div>
          {post.data.tags && post.data.tags.length > 0 && (
            <div class="blog-tags">
              {post.data.tags.map((tag: string) => (
                <span class="blog-tag">{tag}</span>
              ))}
            </div>
          )}
        </div>
        {post.data.image!! && (
          <div class="header-image">
            <img src={post.data.image} alt={post.data.title} />
          </div>
        )}
      </header>

      <div class="blog-content" data-lang={language}>
        <slot />
      </div>
    </article>
  </div>

  <style>
    .blog-container {
      position: relative;
      max-width: 1200px;
      margin: 0 auto;
      padding: 2rem 1rem;
      display: flex;
      gap: 3rem;
      align-items: flex-start;
    }

    .blog-container.no-toc {
      justify-content: center;
    }

    .reading-progress {
      position: fixed;
      top: 0;
      left: 0;
      width: 0%;
      height: 3px;
      background: linear-gradient(90deg, var(--accent-glow), var(--accent-warm));
      z-index: 3;
      transition: width 0.2s ease;
    }


    .blog-post {
      background: var(--glass-bg);
      border: 1px solid var(--glass-border);
      border-radius: var(--card-radius);
      backdrop-filter: blur(20px);
      box-shadow: var(--glass-shadow);
      overflow: hidden;
      position: relative;
      flex: 1;
      order: 1;
      max-width: 800px;
    }

    .blog-post::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 1px;
      background: linear-gradient(90deg, transparent, var(--accent-glow), transparent);
      opacity: 0.6;
    }

    .blog-header {
      text-align: center;
      padding: 2rem 2rem 0;
      background: transparent;
      border-bottom: none;
      position: relative;
    }

    .blog-header-content {
      position: relative;
      z-index: 2;
      margin-bottom: 2rem;
    }

    .classification-tag {
      display: inline-block;
      background: var(--accent);
      color: white;
      padding: 0.5rem 1rem;
      border-radius: 15px;
      font-size: 0.75rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      margin-bottom: 1.5rem;
      font-family: 'Montserrat', sans-serif;
    }

    .blog-title {
      font-family: 'Sora', sans-serif;
      font-size: clamp(1.8rem, 4vw, 2.5rem);
      font-weight: 700;
      line-height: 1.2;
      margin: 0 2rem 1.5rem 2rem;
      color: white;
      text-shadow: var(--text-glow);
    }

    .blog-meta {
      display: flex;
      justify-content: center;
      align-items: center;
      gap: 2rem;
      font-family: 'Sora', sans-serif;
      font-size: 0.9rem;
      color: var(--text-secondary);
      margin-bottom: 0;
    }

    .meta-item {
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }

    .publish-date {
      font-weight: 400;
      color: var(--text-secondary);
    }

    .reading-time {
      font-weight: 400;
      color: var(--text-secondary);
    }

    .header-image {
      margin: 2rem 0 0 0;
      border-radius: 12px;
      overflow: hidden;
      box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
    }

    .header-image img {
      width: 100%;
      height: auto;
      display: block;
      border-radius: 12px;
    }

    .blog-tags {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 0.5rem;
      margin: 1.5rem 0 0 0;
    }

    .blog-content {
      padding: 3rem;
      padding-right: 4rem;
      color: var(--text-secondary);
      line-height: 1.8;
      font-size: 1.1rem;
    }

    .blog-content :global(h2) {
      font-family: 'Sora', sans-serif;
      font-size: 1.8rem;
      font-weight: 600;
      color: var(--text-primary);
      margin: 6rem 0 3rem 0;
      padding-bottom: 1rem;
      border-bottom: 2px solid var(--glass-border);
      position: relative;
    }

    .blog-content :global(h2::after) {
      content: '';
      position: absolute;
      bottom: -2px;
      left: 0;
      width: 40px;
      height: 2px;
      background: var(--accent-glow);
    }

    .blog-content :global(h3) {
      font-family: 'Sora', sans-serif;
      font-size: 1.4rem;
      font-weight: 600;
      color: var(--text-primary);
      margin: 2rem 0 0.8rem 0;
    }

    .blog-content :global(p) {
      margin-bottom: 1.5rem;
      font-family: 'Nunito Sans', sans-serif;
    }

    .blog-content :global(ul),
    .blog-content :global(ol),
    .blog-content :global(li) {
      font-family: 'Nunito Sans', sans-serif;
    }

    /* Chinese paragraphs override */
    .blog-content[data-lang="zh"] :global(p),
    .blog-content[data-lang="zh"] :global(ul),
    .blog-content[data-lang="zh"] :global(ol),
    .blog-content[data-lang="zh"] :global(li) {
      font-family: 'LXGW WenKai', 'PingFang SC', 'Microsoft YaHei', sans-serif;
      font-weight: 400;
    }

    .blog-content[data-lang="zh"] :global(strong),
    .blog-content[data-lang="zh"] :global(b) {
      font-family: 'LXGW WenKai', 'PingFang SC', 'Microsoft YaHei', sans-serif;
      font-weight: 700;
      color: var(--text-primary);
    }

    .blog-content :global(blockquote) {
      background: var(--glass-bg);
      border-left: 4px solid var(--accent-glow);
      padding: 0.5rem 1rem;
      margin: 0.5rem 0;
      border-radius: 0 8px 8px 0;
      box-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);
      font-style: italic;
      font-size: 1.1rem;
      line-height: 1.4;
      font-family: 'Nunito Sans', sans-serif;
      color: var(--text-secondary);
    }

    .blog-content :global(code) {
      background: var(--glass-bg);
      border: 1px solid var(--glass-border);
      padding: 0.2rem 0.5rem;
      border-radius: 6px;
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.9em;
      color: var(--accent-glow);
    }

    .blog-content :global(pre) {
      background: var(--secondary-navy);
      border: 1px solid var(--glass-border);
      padding: 2rem;
      border-radius: 12px;
      margin: 2rem 0;
      overflow-x: auto;
      box-shadow: 0 8px 32px rgba(0, 0, 0, 0.5);
    }

    .blog-content :global(th),
    .blog-content :global(td) {
      padding: 0.6rem 0.6rem;
      border: 1px solid var(--glass-border);
    }

    .blog-content :global(pre code) {
      background: none;
      border: none;
      padding: 0;
      color: var(--text-primary);
    }

    .blog-content :global(img) {
      border-radius: 12px;
      box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
      margin: 2rem 0;
      transition: transform 0.3s ease;
    }

    .blog-content :global(img:hover) {
      transform: scale(1.02);
    }

    @media (max-width: 1024px) {
      .table-of-contents {
        display: none;
      }

      .blog-container {
        max-width: 900px;
        flex-direction: column;
        gap: 0;
      }

      .blog-post {
        max-width: none;
        order: 1;
      }
    }

    @media (max-width: 768px) {
      .blog-container {
        padding: 1rem 0.5rem;
      }

      .blog-header {
        padding: 1.5rem 1rem 0;
      }

      .blog-meta {
        flex-direction: column;
        gap: 1rem;
      }

      .blog-content {
        padding: 2rem 1.5rem;
        font-size: 1rem;
      }

      .blog-title {
        font-size: clamp(1.8rem, 8vw, 2.5rem);
      }

      .blog-meta {
        font-size: 0.9rem;
      }

      .blog-content :global(h2) {
        font-size: 1.5rem;
      }

      .blog-content :global(h3) {
        font-size: 1.25rem;
      }
    }

    @media (max-width: 480px) {
      .blog-container {
        padding: 0;
      }
      
      /* Responsive table styling */
      .blog-content :global(table) {
        width: calc(100% + 1.6rem);
        border-collapse: collapse;
        margin-left: -0.8rem;
        font-size: 0.75rem;
        display: block;             /* allow horizontal scroll on narrow screens */
        overflow-x: auto;
      }

      .blog-content :global(th),
      .blog-content :global(td) {
        padding: 0.4rem 0.4rem;
        text-align: left;
        word-break: break-word;
      }
    }
  </style>

  <script>
    // Reading progress indicator
    function updateReadingProgress() {
      const article = document.querySelector('.blog-content');
      const progressBar = document.getElementById('reading-progress');
      
      if (!(article instanceof HTMLElement) || !progressBar) return;

      const articleTop = article.offsetTop;
      const articleHeight = article.offsetHeight;
      const windowHeight = window.innerHeight;
      const scrollTop = window.scrollY;
      
      const progress = Math.min(
        Math.max(
          (scrollTop - articleTop + windowHeight / 3) / articleHeight,
          0
        ),
        1
      );
      
      progressBar.style.width = `${progress * 100}%`;
    }

    function wrapImagesWithLinks() {
      const article = document.querySelector('.blog-content');
      if (!(article instanceof HTMLElement)) return;

      const images = article.querySelectorAll('img');
      images.forEach((img) => {
        if (img.closest('a') || !img.src) return;

        const anchor = document.createElement('a');
        anchor.href = img.src;
        // Open image in new tab
        anchor.target = '_blank';
        // When opening the image, don't give it any relationship to the current page
        anchor.rel = 'noopener noreferrer';
        // Add 'data-image-wrapper' attribute to the anchor element
        anchor.dataset.imageWrapper = 'true';

        // Move the image inside the anchor link element.
        img.parentElement?.insertBefore(anchor, img);
        anchor.appendChild(img);
      });
    }


    // Throttled scroll handler
    let ticking = false;
    function onScroll() {
      if (!ticking) {
        requestAnimationFrame(() => {
          updateReadingProgress();
          ticking = false;
        });
        ticking = true;
      }
    }

    // Initialize
    document.addEventListener('DOMContentLoaded', () => {
      updateReadingProgress();
      wrapImagesWithLinks();
    });
    
    window.addEventListener('scroll', onScroll);
    window.addEventListener('resize', updateReadingProgress);
  </script>
</MainLayout>
