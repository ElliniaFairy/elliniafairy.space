---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<div class="hero-content">
					<h1 class="hero-title">✨ Welcome to My Universe</h1>
					<p class="hero-subtitle">Where dreams meet code, and ideas come alive in gentle light</p>
				</div>
			</section>

			<section class="blog-redirect-section">
				<div class="blog-redirect-card">
					<div class="blog-content-left">
						<h2 class="blog-main-title">Ready to Explore My Digital Universe?</h2>
						<p class="blog-description">Discover insights, tutorials, and creative processes. Dive deep into my thoughts on technology, development, and innovative solutions.</p>
						<a href="/blog" class="blog-cta-btn">
							Start Reading
							<svg width="16" height="16" viewBox="0 0 24 24" fill="none">
								<path d="M7 17L17 7M17 7H7M17 7V17" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
							</svg>
						</a>
					</div>
					<div class="blog-preview-right">
						<div class="preview-window">
							<div class="window-header">
								<div class="window-dots">
									<span class="dot"></span>
									<span class="dot"></span>
									<span class="dot"></span>
								</div>
							</div>
							<div class="preview-content">
								<div class="stylish-dashboard">
									<div class="dashboard-title">My Blog</div>
									<div class="stats-grid">
										<div class="stat-box">
											<div class="stat-icon">📝</div>
											<div class="stat-value">42</div>
											<div class="stat-desc">Articles</div>
										</div>
										<div class="stat-box">
											<div class="stat-icon">🕒</div>
											<div class="stat-value">Today</div>
											<div class="stat-desc">Updated</div>
										</div>
									</div>
									<div class="activity-bar">
										<div class="activity-dot active"></div>
										<div class="activity-dot"></div>
										<div class="activity-dot"></div>
										<div class="activity-dot active"></div>
										<div class="activity-dot"></div>
										<div class="activity-dot active"></div>
									</div>
								</div>
							</div>
						</div>
					</div>
				</div>
			</section>

			<section class="content-grid">

				<div class="glass-card">
					<h2>🌟 About Me</h2>
					<p>Discover my journey, passion for technology, and the creative process behind every project I craft.</p>
					<a href="/about" class="card-link">Learn More →</a>
				</div>

				<div class="glass-card">
					<h2>💫 Recent Work</h2>
					<p>A collection of projects that showcase my dedication to beautiful, functional, and meaningful design.</p>
					<a href="/about" class="card-link">View Projects →</a>
				</div>
			</section>
		</main>

		<div class="glow-effect glow-left"></div>
		<div class="glow-effect glow-right"></div>
		<div class="neuro-glow-effect"></div>
		<Footer />

		<script>
			// Set random position for the green glow effect that changes with each pulse cycle
			const glowElement = document.querySelector('.neuro-glow-effect');
			if (glowElement) {
				function updateRandomPosition() {
					glowElement.style.setProperty('--random-x', Math.random());
					glowElement.style.setProperty('--random-y', Math.random());
				}
				
				// Set initial position
				updateRandomPosition();
				
				// Listen for animation iteration to sync with the pulse cycle
				glowElement.addEventListener('animationiteration', updateRandomPosition);
			}
		</script>

		<style>
			.hero {
				text-align: center;
				padding: 5rem 0;
				margin-bottom: 1rem;
			}

			.hero-content {
				max-width: 1000px;
				margin: 0 auto;
			}

			.hero-title {
				font-size: 3.5rem;
				font-weight: 700;
				margin-bottom: 1rem;
				background: linear-gradient(135deg, var(--accent-ultimate-purple), var(--accent-warm));
				-webkit-background-clip: text;
				-webkit-text-fill-color: transparent;
				background-clip: text;
				text-shadow: none;
			}

			.hero-subtitle {
				font-size: 1.2rem;
				color: var(--text-secondary);
				margin-bottom: 1rem;
				font-weight: 300;
			}

			.blog-redirect-section {
				margin: 1rem 0 4rem 0;
				width: 100%;
				position: relative;
			}

			.blog-redirect-card {
				background: linear-gradient(135deg, rgba(41, 121, 255, 0.1) 0%, rgba(34, 211, 238, 0.05) 100%);
				backdrop-filter: blur(20px);
				border: 1px solid rgba(255, 255, 255, 0.1);
				border-radius: 24px;
				padding: 0;
				overflow: hidden;
				position: relative;
				display: flex;
				align-items: center;
				min-height: 400px;
				box-shadow: 
					0 20px 40px rgba(0, 0, 0, 0.3),
					0 0 80px rgba(138, 43, 226, 0.2),
					0 0 120px rgba(147, 112, 219, 0.15),
					inset 0 1px 0 rgba(255, 255, 255, 0.1);
			}

			.blog-redirect-card::before {
				content: '';
				position: absolute;
				top: 0;
				left: 0;
				right: 0;
				bottom: 0;
				background: radial-gradient(circle at 20% 50%, rgba(41, 121, 255, 0.15) 0%, transparent 50%),
							radial-gradient(circle at 80% 80%, rgba(34, 211, 238, 0.1) 0%, transparent 50%);
				pointer-events: none;
			}

			.blog-content-left {
				flex: 1;
				padding: 3rem;
				z-index: 2;
				position: relative;
			}

			.blog-main-title {
				font-size: 2.8rem;
				font-weight: 700;
				color: var(--text-primary);
				margin-bottom: 1.5rem;
				line-height: 1.2;
				font-family: 'Montserrat', sans-serif;
				text-shadow: 0 0 20px rgba(255, 255, 255, 0.1);
			}

			.blog-description {
				font-size: 1.1rem;
				color: var(--text-secondary);
				line-height: 1.6;
				margin-bottom: 2.5rem;
				opacity: 0.9;
			}

			.blog-cta-btn {
				display: inline-flex;
				align-items: center;
				gap: 0.5rem;
				background: linear-gradient(135deg, var(--accent) 0%, var(--accent-glow) 100%);
				color: white;
				padding: 1rem 2rem;
				border-radius: 30px;
				text-decoration: none;
				font-weight: 600;
				font-size: 1rem;
				font-family: 'Montserrat', sans-serif;
				transition: all 0.3s ease;
				box-shadow: 
					0 8px 20px rgba(41, 98, 255, 0.3),
					0 0 0 1px rgba(255, 255, 255, 0.1);
				position: relative;
				overflow: hidden;
			}

			.blog-cta-btn:hover {
				transform: translateY(-2px);
				box-shadow: 
					0 12px 30px rgba(41, 98, 255, 0.4),
					0 0 40px rgba(34, 211, 238, 0.3);
			}

			.blog-cta-btn svg {
				transition: transform 0.3s ease;
			}

			.blog-cta-btn:hover svg {
				transform: translate(2px, -2px);
			}

			.blog-preview-right {
				flex: 1;
				padding: 2rem;
				display: flex;
				justify-content: center;
				align-items: center;
			}

			.preview-window {
				width: 100%;
				max-width: 400px;
				background: rgba(255, 255, 255, 0.03);
				border: 1px solid rgba(41, 121, 255, 0.3);
				border-radius: 16px;
				overflow: hidden;
				backdrop-filter: blur(10px);
				box-shadow: 
					0 8px 32px rgba(0, 0, 0, 0.3),
					0 0 40px rgba(41, 121, 255, 0.3),
					0 0 60px rgba(34, 211, 238, 0.2),
					inset 0 1px 0 rgba(255, 255, 255, 0.1);
			}

			.window-header {
				background: rgba(255, 255, 255, 0.05);
				padding: 1rem;
				border-bottom: 1px solid rgba(255, 255, 255, 0.1);
			}

			.window-dots {
				display: flex;
				gap: 0.5rem;
			}

			.dot {
				width: 8px;
				height: 8px;
				border-radius: 50%;
				background: var(--text-muted);
				opacity: 0.6;
			}

			.dot:first-child {
				background: #ff5f57;
			}

			.dot:nth-child(2) {
				background: #ffbd2e;
			}

			.dot:last-child {
				background: #28ca42;
			}

			.preview-content {
				display: flex;
				height: 250px;
			}

			.stylish-dashboard {
				width: 100%;
				padding: 1.5rem;
				display: flex;
				flex-direction: column;
				justify-content: space-between;
				height: 100%;
			}

			.dashboard-title {
				font-size: 0.9rem;
				color: var(--text-primary);
				margin-bottom: 1rem;
				font-weight: 700;
				font-family: 'Montserrat', sans-serif;
				text-align: center;
				opacity: 0.9;
			}

			.stats-grid {
				display: flex;
				gap: 1rem;
				flex: 1;
				align-items: center;
				justify-content: center;
			}

			.stat-box {
				background: rgba(255, 255, 255, 0.03);
				border: 1px solid rgba(255, 255, 255, 0.08);
				border-radius: 12px;
				padding: 1rem 0.8rem;
				text-align: center;
				flex: 1;
				transition: all 0.3s ease;
				backdrop-filter: blur(5px);
			}

			.stat-box:hover {
				transform: translateY(-2px);
				border-color: rgba(41, 121, 255, 0.3);
				box-shadow: 0 4px 20px rgba(41, 121, 255, 0.1);
			}

			.stat-icon {
				font-size: 1.2rem;
				margin-bottom: 0.5rem;
				opacity: 0.8;
			}

			.stat-value {
				font-size: 1.4rem;
				font-weight: 700;
				color: var(--accent-glow);
				font-family: 'Montserrat', sans-serif;
				margin-bottom: 0.3rem;
			}

			.stat-desc {
				font-size: 0.7rem;
				color: var(--text-muted);
				text-transform: uppercase;
				letter-spacing: 0.5px;
				font-weight: 500;
			}

			.activity-bar {
				display: flex;
				gap: 0.4rem;
				justify-content: center;
				margin-top: 1rem;
				padding-top: 1rem;
				border-top: 1px solid rgba(255, 255, 255, 0.05);
			}

			.activity-dot {
				width: 6px;
				height: 6px;
				border-radius: 50%;
				background: rgba(255, 255, 255, 0.2);
				transition: all 0.3s ease;
			}

			.activity-dot.active {
				background: var(--accent-glow);
				box-shadow: 0 0 8px rgba(34, 211, 238, 0.4);
			}


			.content-grid {
				display: grid;
				grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
				gap: 3rem;
				padding: 0;
				max-width: 100%;
				margin: 0 auto;
			}

			.glass-card {
				background: var(--glass-bg);
				backdrop-filter: blur(10px);
				border: 1px solid var(--glass-border);
				border-radius: 16px;
				padding: 2rem;
				box-shadow: var(--glass-shadow);
				transition: all 0.3s ease;
			}

			.glass-card:hover {
				transform: translateY(-5px);
				box-shadow: 0 12px 40px rgba(0, 0, 0, 0.4);
				border-color: var(--accent-glow);
			}

			.glass-card h2 {
				color: var(--text-primary);
				margin-bottom: 1rem;
				font-size: 1.5rem;
			}

			.glass-card p {
				color: var(--text-secondary);
				line-height: 1.6;
				margin-bottom: 1.5rem;
			}

			.card-link {
				color: var(--accent-glow);
				font-weight: 500;
				text-decoration: none;
				transition: all 0.3s ease;
			}

			.card-link:hover {
				color: var(--accent-warm);
				text-shadow: 0 0 10px var(--accent-warm);
			}


			@media (max-width: 768px) {
				.hero-title {
					font-size: 2.5rem;
				}
				
				.blog-redirect-card {
					flex-direction: column;
					min-height: auto;
					margin: 0 1rem;
				}

				.blog-content-left {
					padding: 2rem 1.5rem;
				}

				.blog-main-title {
					font-size: 2rem;
				}

				.blog-preview-right {
					padding: 1rem;
				}

				.preview-window {
					max-width: 100%;
				}

				.preview-content {
					height: 200px;
				}

				.content-grid {
					grid-template-columns: 1fr;
					padding: 0 1rem;
				}
			}
		</style>
	</body>
</html>
