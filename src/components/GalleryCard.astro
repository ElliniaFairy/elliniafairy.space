---
export interface Props {
	title: string;
	description: string;
	coverImage: string;
	imageCount: number;
	href: string;
}

const { title, description, coverImage, imageCount, href } = Astro.props;
---

<article class="gallery-card">
	<a href={href} class="card-link">
		<div class="gallery-image">
			<img src={coverImage} alt={title} class="cover-image" />
			<div class="image-overlay">
				<span class="image-count">
					<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
						<rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
						<circle cx="8.5" cy="8.5" r="1.5"></circle>
						<polyline points="21 15 16 10 5 21"></polyline>
					</svg>
					{imageCount} {imageCount === 1 ? 'image' : 'images'}
				</span>
			</div>
		</div>
		<div class="gallery-content">
			<h3 class="gallery-title">{title}</h3>
			<p class="gallery-description">{description}</p>
		</div>
	</a>
</article>

<style>
	.gallery-card {
		background: var(--glass-bg);
		backdrop-filter: blur(20px);
		border: 1px solid var(--glass-border);
		border-radius: 20px;
		overflow: hidden;
		transition: all 0.3s ease;
		box-shadow: var(--glass-shadow);
		height: 100%;
		display: flex;
		flex-direction: column;
	}

	.gallery-card:hover {
		border-image: linear-gradient(90deg, transparent, var(--accent-glow), transparent) 1;
		transform: translateY(-5px);
		box-shadow:
			0 20px 60px rgba(0, 0, 0, 0.3),
			0 8px 16px rgba(0, 0, 0, 0.15),
			0 0 40px rgba(34, 211, 238, 0.3);
	}

	.card-link {
		text-decoration: none;
		color: inherit;
		display: flex;
		flex-direction: column;
		height: 100%;
	}

	/* Prevent global link hover glow from affecting text inside cards */
	.card-link:hover .gallery-title,
	.card-link:hover .gallery-description {
		text-shadow: none;
		color: inherit;
	}

	.gallery-image {
		position: relative;
		width: 100%;
		height: 300px;
		overflow: hidden;
	}

	.cover-image {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.5s ease;
	}

	.gallery-card:hover .cover-image {
		transform: scale(1.1);
	}

	.image-overlay {
		position: absolute;
		bottom: 0;
		left: 0;
		right: 0;
		background: linear-gradient(to top, rgba(0, 0, 0, 0.8), transparent);
		padding: 1rem;
		display: flex;
		justify-content: flex-end;
	}

	.image-count {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		color: white;
		font-size: 0.9rem;
		font-weight: 600;
		background: rgba(255, 255, 255, 0.1);
		backdrop-filter: blur(10px);
		padding: 0.5rem 1rem;
		border-radius: 20px;
		border: 1px solid rgba(255, 255, 255, 0.2);
	}

	.gallery-content {
		padding: 1.5rem;
		flex: 1;
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}

	.gallery-title {
		color: var(--text-primary);
		font-size: 1.5rem;
		font-weight: 700;
		margin: 0;
		font-family: 'Montserrat', sans-serif;
		line-height: 1.3;
	}

	.gallery-description {
		color: var(--text-secondary);
		font-size: 1rem;
		line-height: 1.6;
		margin: 0;
		opacity: 0.9;
	}

	@media (max-width: 768px) {
		.gallery-image {
			height: 200px;
		}

		.gallery-title {
			font-size: 1.25rem;
		}

		.gallery-description {
			font-size: 0.9rem;
		}
	}
</style>
