---
import MainLayout from '../layouts/MainLayout.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import { getCollection } from 'astro:content';
import { resolveLanguage, useTranslations } from '../utils/language';

export const prerender = false;

const language = resolveLanguage(
  Astro.url.searchParams.get('lang'),
  Astro.cookies.get('language')?.value,
);

const t = useTranslations(language);

const posts = (await getCollection('blog')).filter(post => post.data.language === language);
const postCount = posts.length;
const latestPost = posts.sort((a, b) => new Date(b.data.publishDate).valueOf() - new Date(a.data.publishDate).valueOf())[0];
const dateLocale = language === 'zh' ? 'zh-CN' : language === 'ja' ? 'ja-JP' : 'en-US';
const lastUpdated = latestPost ? new Date(latestPost.data.publishDate).toLocaleDateString(dateLocale, { month: 'short', day: 'numeric' }) : 'Never';

const albums = (await getCollection('gallery')).filter(album => album.data.language === language);
const albumCount = albums.length;
const totalImages = albums.reduce((acc, album) => acc + album.data.images.length, 0);
---

<MainLayout title={SITE_TITLE} description={SITE_DESCRIPTION} glowing={true}>
	<section class="hero">
		<div class="hero-content">
			<h1 class="hero-title">✨ <span class="text-full">{t('home.heroTitle')}</span><span class="text-short">{t('home.heroTitleShort')}</span></h1>
			<p class="hero-subtitle">{t('home.heroSubtitle')}</p>
		</div>
	</section>

	<section class="blog-redirect-section">
		<div class="blog-redirect-card">
			<div class="blog-content-left">
				<h2 class="blog-main-title"><span class="text-full">{t('home.blogTitle')}</span><span class="text-short">{t('home.blogTitleShort')}</span></h2>
				<p class="blog-description">{t('home.blogDescription')}</p>
				<a href="/blog" class="blog-cta-btn">
					{t('home.blogCta')}
					<svg width="16" height="16" viewBox="0 0 24 24" fill="none">
						<path d="M7 17L17 7M17 7H7M17 7V17" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
					</svg>
				</a>
			</div>
			<div class="blog-preview-right">
				<div class="preview-window">
					<div class="window-header">
						<div class="window-dots">
							<span class="dot"></span>
							<span class="dot"></span>
							<span class="dot"></span>
						</div>
					</div>
					<div class="preview-content">
						<div class="stylish-dashboard">
							<div class="dashboard-title">{t('home.blogDashboard')}</div>
							<div class="stats-grid">
								<div class="stat-box">
									<div class="stat-icon">📝</div>
									<div class="stat-value">{postCount}</div>
									<div class="stat-desc">{t('home.blogArticles')}</div>
								</div>
								<div class="stat-box">
									<div class="stat-icon">🕒</div>
									<div class="stat-value">{lastUpdated}</div>
									<div class="stat-desc">{t('home.blogUpdated')}</div>
								</div>
							</div>
							<div class="activity-bar">
								<div class="activity-dot active"></div>
								<div class="activity-dot"></div>
								<div class="activity-dot"></div>
								<div class="activity-dot active"></div>
								<div class="activity-dot"></div>
								<div class="activity-dot active"></div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>

