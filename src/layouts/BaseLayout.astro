---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
interface Props {
  title: string;
  description: string;
  image?: string;
  showFooter?: boolean;
}

const { title, description, image, showFooter = true } = Astro.props as Props;
---
<!doctype html>
<html lang="en">
  <head>
    <BaseHead {title} {description} image={image} />
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    {showFooter && <Footer />}
  </body>
</html>
