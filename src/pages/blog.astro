---
import MainLayout from '../layouts/MainLayout.astro';
import BlogCard from '../components/BlogCard.astro';
import { SITE_TITLE } from '../consts';
import { getCollection } from 'astro:content';
import { resolveLanguage, useTranslations } from '../utils/language';

export const prerender = false; // Should filter the blog by language

const language = resolveLanguage(
  Astro.url.searchParams.get('lang'),
  Astro.cookies.get('language')?.value,
);

const posts = (await getCollection('blog'))
  .filter(post => post.data.language === language)
  .filter(post => !post.data.draft)
  .sort(
    (a, b) => new Date(b.data.publishDate).valueOf() - new Date(a.data.publishDate).valueOf(),
  );

// Get unique categories
const categories = [...new Set(posts.map(post => post.data.classification))];
const t = useTranslations(language)
---

<MainLayout title={`Blog - ${SITE_TITLE}`} description="Stay ahead with the latest trends, tips, and insights" glowing={true}>
	<section class="hero">
		<div class="hero-content">
			<h1 class="hero-title"><span class="emoji">📖</span> {t('bloglist.readmyblog')}</h1>
			<p class="hero-subtitle">{t('bloglist.description')}</p>
		</div>
	</section>

	<section class="filter-section">
		<div class="category-filters">
			<button class="filter-btn active" data-category="all">{t('bloglist.allcategories')}</button>
			{categories.map(category => (
				<button class="filter-btn" data-category={category}>{category}</button>
			))}
		</div>
	</section>

	<section class="blog-grid">
		{posts.map((post) => (
			<div
				class="blog-item"
				data-category={post.data.classification}
				data-language={post.data.language}
			>
				<BlogCard
					title={post.data.title}
					excerpt={post.data.description}
					date={post.data.publishDate}
					category={post.data.classification}
					readingTime={post.data.readingTime}
					tags={post.data.tags}
					thumbnailSrc={post.data.image}
					thumbnailAlt={post.data.title}
					href={`/blogs/${post.slug}`}
					language={language}
				/>
			</div>
		))}
	</section>
</MainLayout>

<style>
	.hero {
		text-align: center;
		padding: 4rem 0 2rem 0;
		margin-bottom: 1.5rem;
	}

	.hero-content {
		max-width: 800px;
		margin: 0 auto;
	}

	.hero-title {
		font-size: 3.5rem;
		font-weight: 700;
		margin-bottom: 1rem;
		background: linear-gradient(135deg, var(--text-primary), var(--accent-glow));
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
		text-shadow: none;
	}

	/* Prevent emoji from being rendered by gradient */
	.hero-title .emoji {
		-webkit-background-clip: initial;
		-webkit-text-fill-color: initial;
		background-clip: initial;
		color: initial;
	}

	.hero-subtitle {
		font-size: 1.1rem;
		color: var(--text-secondary);
		margin-bottom: 1rem;
		font-weight: 400;
	}

	.filter-section {
		margin-bottom: 3rem;
		display: flex;
		justify-content: center;
	}

	.category-filters {
		display: flex;
		gap: 0.5rem;
		flex-wrap: wrap;
		justify-content: center;
	}

	.filter-btn {
		background: transparent;
		border: 1px solid var(--glass-border);
		color: var(--text-secondary);
		padding: 0.75rem 1.5rem;
		border-radius: 25px;
		font-size: 0.95rem;
		font-weight: 600;
		font-family: 'Montserrat', sans-serif;
		cursor: pointer;
		transition: all 0.3s ease;
		backdrop-filter: blur(10px);
		letter-spacing: 0.3px;
	}

	.filter-btn:hover,
	.filter-btn.active {
		background: var(--accent);
		color: white;
		border-color: var(--accent);
		box-shadow: 0 0 20px rgba(41, 121, 255, 0.3);
	}

	.blog-grid {
		display: flex;
		flex-direction: column;
		gap: 2rem;
		max-width: 1200px;
		margin: 0 auto;
	}


	@media (max-width: 768px) {
		.hero-title {
			font-size: 2.5rem;
		}
		
		.blog-grid {
			padding: 0 1rem;
		}

		.category-filters {
			padding: 0 1rem;
		}

		.filter-btn {
			padding: 0.6rem 1.2rem;
			font-size: 0.85rem;
		}
	}

	@media (max-width: 480px) {
		.hero {
			padding: 3rem 0 2rem 0;
		}

		.hero-title {
			font-size: 2rem;
		}

	}
</style>

<script>
	import { getCurrentLanguage } from '../utils/language';

	document.addEventListener('DOMContentLoaded', () => {
		const currentLanguage = getCurrentLanguage();

		const applyFilters = (category: string | undefined) => {
			const activeCategory = category ?? 'all';
			const blogItems = document.querySelectorAll('.blog-item') as NodeListOf<HTMLElement>;
			blogItems.forEach((item) => {
				const categoryMatch = activeCategory === 'all' || item.dataset.category === activeCategory;
				const languageMatch = item.dataset.language === currentLanguage;
				item.style.display = categoryMatch && languageMatch ? 'block' : 'none';
			});
		};

		const getActiveCategory = () => {
			const activeBtn = document.querySelector('.filter-btn.active') as HTMLButtonElement | null;
			return activeBtn?.dataset.category ?? 'all';
		};

		const filterBtns = document.querySelectorAll('.filter-btn') as NodeListOf<HTMLButtonElement>;
		filterBtns.forEach((btn) => {
			btn.addEventListener('click', (event) => {
				const target = event.currentTarget as HTMLButtonElement | null;
				if (!target) return;
				const category = target.dataset.category;

				filterBtns.forEach(b => b.classList.remove('active'));
				target.classList.add('active');

				applyFilters(category);
			});
		});

		applyFilters(getActiveCategory());
	});
</script>
