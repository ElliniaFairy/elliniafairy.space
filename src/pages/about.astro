---
import MainLayout from '../layouts/MainLayout.astro';
import { Image } from 'astro:assets';
import avatar from '../assets/avatar/avatar.png';
import WeiboIcon from '../components/WeiboIcon.astro';
import BilibiliIcon from '../components/BilibiliIcon.astro';
import ArrowIcon from '../components/ArrowIcon.astro';
import EmailIcon from '../components/EmailIcon.astro';
import AboutMap from '../components/AboutMap.astro';

---

<MainLayout title="About - Ellinia Fairy" description="Learn about Ellinia Fairy - a mathematics graduate turned app developer, exploring the intersection of intelligence and aesthetics through technology and creativity." footer={false} glowing={true}>
	<div class="hero-content">
		<div class="hero-text">
			<h1 class="hero-title">
				🍃 About Me
			</h1>
			<div class="hero-intro">
				<p>I'm <strong>Ellinia Fairy</strong>—a mathematics master degree graduate turned app developer. I currently work in <strong>Yokohama Minato Mirai 21</strong>, a futuristic district, and live in <strong>Tokyo Haneda</strong>, close to the open skies inspiring my creative spirit.</p>
				<p>I build with logic, but I live for resonance. Technology alone doesn't fascinate me; what deeply resonates are the stories born from technological possibilities and human creativity. I explore the intersection of intelligence and aesthetics through meteorology, storytelling and photography, aiming to blend rigorous science with artistic expression.</p>
			</div>
			<div class="action-section">
				<a href="/about-me" class="find-more-btn">
					<span class="btn-text-full">Find out more about me</span>
					<span class="btn-text-short">More</span>
					<ArrowIcon />
				</a>
				<div class="social-links">
				<a href="https://space.bilibili.com/3981688" target="_blank" class="social-link">
					<span class="sr-only">Visit my Bilibili</span>
					<BilibiliIcon />
				</a>
				<a href="https://weibo.com/u/1666486042" target="_blank" class="social-link">
					<span class="sr-only">Follow me on Weibo</span>
					<WeiboIcon />
				</a>
				<a href="mailto:elliniaharbor@outlook.com" target="_blank" class="social-link">
					<span class="sr-only">Email me</span>
					<EmailIcon />
				</a>
				</div>
			</div>
		</div>
		<div class="hero-visual">
			<div class="avatar-container">
				<div class="eclipse-effect"></div>
				<Image src={avatar} alt="Ellinia Fairy" class="avatar-image" width={240} height={290} />
			</div>
			<div class="map-container">
				<AboutMap />
			</div>
		</div>
	</div>
</MainLayout>

<style>

.hero-content {
	display: grid;
	grid-template-columns: 1fr 1fr;
	gap: 4rem;
	max-width: 1200px;
	width: 100%;
	margin: 0 auto;
	padding: 4rem 2rem;
	align-items: center;
	position: relative;
}

.hero-text {
	padding: 2rem 0;
}

.hero-title {
	font-family: 'Sora', sans-serif;
	font-size: clamp(2rem, 4vw, 3.5rem);
	font-weight: 800;
	line-height: 1.1;
	margin-bottom: 1.5rem;
	color: var(--text-primary);
}

.sparkle {
	display: inline-block;
	animation: sparkleRotate 3s ease-in-out infinite;
	filter: none;
}

.hero-intro {
	font-family: 'Inter', sans-serif;
	font-size: 1.1rem;
	line-height: 1.7;
	color: var(--text-secondary);
	margin-top: 1.5rem;
}

.hero-intro p {
	margin-bottom: 1.2rem;
}

.hero-intro strong {
	color: var(--text-primary);
	font-weight: 600;
}

.find-more-btn {
	display: inline-flex;
	align-items: center;
	gap: 0.5rem;
	background: linear-gradient(135deg, var(--accent) 0%, var(--accent-glow) 100%);
	color: white;
	padding: 1.2rem 1.5rem 1.2em 2.5rem;
	border-radius: 30px;
	text-decoration: none;
	font-weight: 600;
	font-size: 1.1rem;
	font-family: 'Montserrat', sans-serif;
	transition: all 0.3s ease;
	box-shadow: 
		0 8px 20px rgba(41, 98, 255, 0.3),
		0 0 0 1px rgba(255, 255, 255, 0.1);
	position: relative;
	overflow: hidden;
}

.find-more-btn:hover {
	transform: translateY(-2px);
	box-shadow: 
		0 12px 30px rgba(41, 98, 255, 0.4),
		0 0 40px rgba(34, 211, 238, 0.3);
}

.find-more-btn svg {
	transition: transform 0.3s ease;
}

.btn-text-full {
	min-width: 255px;
}

.btn-text-short {
	display: none;
}

.find-more-btn:hover svg {
	transform: translate(2px, -2px);
}

.action-section {
	display: flex;
	align-items: center;
	justify-content: flex-start;
	gap: 2.5rem;
	margin-top: 3rem;
}

.social-links {
	display: flex;
	gap: 0.8rem;
}

.social-link {
	color: var(--text-secondary);
	transition: all 0.3s ease;
	padding: 0.8rem;
	border-radius: 50%;
	background: rgba(255, 255, 255, 0.05);
	border: 1px solid rgba(255, 255, 255, 0.1);
	display: flex;
	align-items: center;
	justify-content: center;
}

.social-link:hover {
	color: var(--accent-glow);
	transform: translateY(-2px);
	box-shadow: 0 8px 20px rgba(0, 255, 255, 0.3);
	background: rgba(0, 255, 255, 0.1);
}

.sr-only {
	position: absolute;
	width: 1px;
	height: 1px;
	padding: 0;
	margin: -1px;
	overflow: hidden;
	clip: rect(0, 0, 0, 0);
	white-space: nowrap;
	border: 0;
}

.hero-visual {
	position: relative;
	height: 100%;
	display: flex;
	align-items: center;
	justify-content: center;
	gap: 4rem;
}

.avatar-container {
	position: relative;
	width: 250px;
	height: 300px;
	display: flex;
	align-items: center;
	justify-content: center;
}

.eclipse-effect {
	position: absolute;
	width: 100%;
	height: 100%;
	border-radius: 50%;
	background: radial-gradient(circle at 30% 30%, 
		rgba(0, 255, 255, 0.4) 0%,
		rgba(138, 43, 226, 0.3) 40%,
		rgba(255, 0, 255, 0.2) 70%,
		transparent 100%
	);
	animation: eclipsePulse 4s ease-in-out infinite;
	z-index: 1;
}

.eclipse-effect::before {
	content: '';
	position: absolute;
	top: 0;
	left: 0;
	right: 0;
	bottom: 0;
	border-radius: 50%;
	background: linear-gradient(45deg, 
		rgba(0, 255, 255, 0.1) 0%,
		transparent 30%,
		transparent 70%,
		rgba(255, 0, 255, 0.1) 100%
	);
	transform: scale(1.1);
	animation: eclipseRotate 6s linear infinite;
}

.avatar-image {
	width: 240px;
	height: 290px;
	border-radius: 50%;
	object-fit: cover;
	border: 3px solid rgba(255, 255, 255, 0.1);
	box-shadow: 
		0 0 30px rgba(0, 255, 255, 0.3),
		0 0 60px rgba(138, 43, 226, 0.2),
		inset 0 0 30px rgba(255, 255, 255, 0.05);
	z-index: 2;
	position: relative;
	transition: transform 0.3s ease;
}


.map-container {
	position: relative;
	width: 270px;
	height: 270px;
	border-radius: 50%;
	overflow: hidden;
	border: 3px solid rgba(255, 255, 255, 0.1);
	box-shadow: 
		0 0 30px rgba(34, 197, 94, 0.4),
		0 0 60px rgba(22, 163, 74, 0.3),
		0 0 90px rgba(16, 185, 129, 0.2),
		inset 0 0 30px rgba(134, 239, 172, 0.05);
	transition: transform 0.3s ease;
}




.google-map {
	width: 100%;
	height: 100%;
	border: none;
	filter: contrast(1.1) brightness(0.9) hue-rotate(15deg);
}

@keyframes backgroundPulse {
	0%, 100% { opacity: 1; }
	50% { opacity: 0.8; }
}

@keyframes sparkleRotate {
	0%, 100% { transform: rotate(0deg) scale(1); }
	25% { transform: rotate(90deg) scale(1.1); }
	50% { transform: rotate(180deg) scale(1); }
	75% { transform: rotate(270deg) scale(1.1); }
}

@keyframes orbPulse {
	0%, 100% { 
		transform: scale(1);
		opacity: 0.8;
	}
	50% { 
		transform: scale(1.1);
		opacity: 1;
	}
}

@keyframes innerGlow {
	0%, 100% { 
		transform: translate(-50%, -50%) scale(1);
		opacity: 0.3;
	}
	50% { 
		transform: translate(-50%, -50%) scale(1.2);
		opacity: 0.6;
	}
}

@keyframes float {
	0%, 100% { 
		transform: translateY(0px) rotate(0deg);
		opacity: 0.8;
	}
	25% { 
		transform: translateY(-20px) rotate(90deg);
		opacity: 1;
	}
	50% { 
		transform: translateY(-10px) rotate(180deg);
		opacity: 0.6;
	}
	75% { 
		transform: translateY(-15px) rotate(270deg);
		opacity: 1;
	}
}

@media (max-width: 666px) {
		
	.find-more-btn {
		padding: 1rem 1.5rem;
	}
	
	.btn-text-full {
		display: none;
	}
	
	.btn-text-short {
		display: inline;
	}

	.hero-visual {
		flex-direction: column;
		justify-content: center;
	}
}
	


@media (max-width: 768px) {
	body {
		overflow-x: hidden;
		max-width: 100%;
	}
	
	main {
		overflow-x: hidden;
		width: 100%;
		max-width: 100%;
		padding: 0.5em 0.5em;
		box-sizing: border-box;
	}
	
	.hero-content {
		grid-template-columns: 1fr;
		gap: 2rem;
		text-align: center;
		padding: 2rem 0.5rem;
		max-width: 100%;
		margin: 0 auto;
		overflow-x: hidden;
		box-sizing: border-box;
	}
	
	.hero-section {
		height: 60vh;
		overflow-x: hidden;
		width: 100%;
		max-width: 100%;
	}

	
	.avatar-container {
		width: 170px;
		height: 200px;
		flex-shrink: 0;
	}
	
	.avatar-image {
		width: 150px;
		height: 180px;
	}
	
	.map-container {
		width: 180px;
		height: 180px;
	}

	.action-section {
		flex-direction: column;
		align-items: center;
		gap: 1.5rem;
	}
	
	.social-links {
		justify-content: center;
	}

}
</style>
