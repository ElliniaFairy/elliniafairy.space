---
import BaseLayout from "./BaseLayout.astro";
import type { CollectionEntry } from "astro:content";

export type BlogPost = CollectionEntry<'blog'>;
const { post } = Astro.props as { post: BlogPost };

// Format date for better display
const formatDate = (date: Date) => {
  return new Intl.DateTimeFormat('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric'
  }).format(new Date(date));
};

---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  image={post.data.image}
>
  <div class="blog-container">
    <div class="reading-progress" id="reading-progress"></div>
    
    <!-- Table of Contents -->
    <nav class="table-of-contents" id="table-of-contents">
      <div class="toc-header">
        <h3>📖 Table of Contents</h3>
      </div>
      <div class="toc-background-effects">
        <div class="toc-energy-line"></div>
        <div class="toc-orbs">
          <div class="toc-orb toc-orb-1"></div>
          <div class="toc-orb toc-orb-2"></div>
          <div class="toc-orb toc-orb-3"></div>
        </div>
        <div class="toc-particles">
          <div class="toc-particle"></div>
          <div class="toc-particle"></div>
          <div class="toc-particle"></div>
          <div class="toc-particle"></div>
        </div>
      </div>
      <ul class="toc-list" id="toc-list">
        <!-- Dynamically populated -->
      </ul>
    </nav>
    
    <article class="blog-post">
      <header class="blog-header">
        <div class="blog-header-content">
          {post.data.classification && (
            <div class="classification-tag">
              {post.data.classification}
            </div>
          )}
          <h1 class="blog-title">{post.data.title}</h1>
          <div class="blog-meta">
            <div class="meta-item">
              📅 <time class="publish-date" datetime={post.data.publishDate}>
                {formatDate(post.data.publishDate)}
              </time>
            </div>
            {post.data.readingTime && (
              <div class="meta-item">
                ⏱️ <span class="reading-time">{post.data.readingTime}</span>
              </div>
            )}
          </div>
          {post.data.tags && post.data.tags.length > 0 && (
            <div class="blog-tags">
              {post.data.tags.map((tag: string) => (
                <span class="blog-tag">{tag}</span>
              ))}
            </div>
          )}
        </div>
        {post.data.image && (
          <div class="header-image">
            <img src={post.data.image} alt={post.data.title} />
          </div>
        )}
      </header>

      <div class="blog-content">
        <slot />
      </div>
    </article>
  </div>

  <style>
    .blog-container {
      position: relative;
      max-width: 1200px;
      margin: 0 auto;
      padding: 2rem 1rem;
      display: flex;
      gap: 3rem;
      align-items: flex-start;
    }

    .reading-progress {
      position: fixed;
      top: 0;
      left: 0;
      width: 0%;
      height: 3px;
      background: linear-gradient(90deg, var(--accent-glow), var(--accent-warm));
      z-index: 1000;
      transition: width 0.2s ease;
    }

    .table-of-contents {
      position: sticky;
      top: 2rem;
      width: 280px;
      max-height: calc(100vh - 4rem);
      overflow-y: auto;
      background: var(--glass-bg);
      border: 1px solid var(--glass-border);
      border-radius: var(--card-radius);
      backdrop-filter: blur(20px);
      box-shadow: var(--glass-shadow);
      padding: 1.5rem;
      flex-shrink: 0;
      order: 1;
      position: relative;
    }

    .toc-header {
      padding: 0 0 1rem 0;
      border-bottom: 2px solid rgba(255, 255, 255, 0.1);
      margin-bottom: 1rem;
      position: relative;
      z-index: 10;
    }

    .toc-header h3 {
      margin: 0;
      font-family: 'Sora', sans-serif;
      font-size: 1.3rem;
      font-weight: 700;
      color: white;
    }

    .toc-background-effects {
      position: absolute;
      top: 60px;
      left: 0;
      right: 0;
      bottom: 0;
      pointer-events: none;
      z-index: 2;
    }

    .toc-tree-structure {
      position: absolute;
      left: 15px;
      top: 0;
      bottom: 0;
      width: 2px;
      background: linear-gradient(
        180deg,
        var(--accent-glow) 0%,
        var(--accent-warm) 50%,
        var(--accent-glow) 100%
      );
      box-shadow: 
        0 0 8px var(--accent-glow),
        0 0 16px rgba(138, 43, 226, 0.4);
      animation: toc-pulse 3s ease-in-out infinite alternate;
    }

    .toc-particles {
      position: absolute;
      left: 10px;
      top: 0;
      bottom: 0;
      width: 12px;
    }

    .toc-particle {
      position: absolute;
      width: 2px;
      height: 2px;
      background: var(--accent-glow);
      border-radius: 50%;
      box-shadow: 0 0 6px var(--accent-glow);
    }

    .toc-particle:nth-child(1) {
      left: 2px;
      animation: toc-particle-float 4s linear infinite;
    }

    .toc-particle:nth-child(2) {
      left: 8px;
      animation: toc-particle-float 3.5s linear infinite;
      animation-delay: 1s;
    }

    .toc-particle:nth-child(3) {
      left: 5px;
      animation: toc-particle-float 4.2s linear infinite;
      animation-delay: 2s;
    }

    .toc-particle:nth-child(4) {
      left: 1px;
      animation: toc-particle-float 3.8s linear infinite;
      animation-delay: 0.5s;
    }

    .toc-list {
      list-style: none;
      padding: 0;
      margin: 0;
      position: relative;
      z-index: 5;
    }

    .toc-list li {
      margin: 0;
      position: relative;
    }

    .table-of-contents .toc-list a {
      display: block;
      padding: 0.5rem 0;
      line-height: 1.5;
      border-left: 3px solid transparent;
      padding-left: 2rem;
      font-family: 'Inter', sans-serif;
      transition: all 0.3s ease;
      position: relative;
      border-radius: 6px;
      margin: 2px 0;
    }

    .table-of-contents .toc-list a:hover {
      border-left-color: var(--accent-glow);
      background: rgba(138, 43, 226, 0.1);
      box-shadow: 0 0 15px rgba(138, 43, 226, 0.2);
      transform: translateX(3px);
    }

    .table-of-contents .toc-list a.active {
      border-left-color: var(--accent-glow);
      background: linear-gradient(90deg, 
        rgba(138, 43, 226, 0.3) 0%, 
        rgba(138, 43, 226, 0.1) 100%);
      box-shadow: 
        0 0 20px rgba(138, 43, 226, 0.4),
        inset 0 0 10px rgba(138, 43, 226, 0.2);
      font-weight: 600;
      color: var(--accent-glow);
      transform: translateX(5px);
    }

    .table-of-contents .toc-list a.active::before {
      content: '▶';
      position: absolute;
      left: 0.5rem;
      color: var(--accent-glow);
      font-size: 0.8rem;
      animation: pulse-arrow 1s ease-in-out infinite alternate;
    }

    .table-of-contents .toc-list a.active::after {
      content: '';
      position: absolute;
      right: 0.5rem;
      top: 50%;
      transform: translateY(-50%);
      width: 6px;
      height: 6px;
      background: var(--accent-glow);
      border-radius: 50%;
      box-shadow: 0 0 10px var(--accent-glow);
      animation: glow-pulse 1.5s ease-in-out infinite;
    }

    
    .table-of-contents .toc-list a.toc-h2 {
      padding-left: 1rem;
    }

    .table-of-contents .toc-list a.toc-h3 {
      padding-left: 2rem;
    }

    .table-of-contents .toc-list a.toc-h4 {
      padding-left: 3rem;
    }

    /* TOC Animation Keyframes */
    @keyframes toc-pulse {
      0% {
        opacity: 0.6;
        box-shadow: 
          0 0 8px var(--accent-glow),
          0 0 16px rgba(138, 43, 226, 0.4);
      }
      100% {
        opacity: 1;
        box-shadow: 
          0 0 16px var(--accent-glow),
          0 0 32px rgba(138, 43, 226, 0.6);
      }
    }

    @keyframes toc-float {
      0%, 100% {
        transform: translateY(-5px);
      }
      50% {
        transform: translateY(5px);
      }
    }

    @keyframes toc-particle-float {
      0% {
        bottom: 0;
        opacity: 0;
      }
      10% {
        opacity: 1;
      }
      90% {
        opacity: 1;
      }
      100% {
        bottom: 100%;
        opacity: 0;
      }
    }

    @keyframes pulse-arrow {
      0% {
        opacity: 0.7;
        transform: scale(1);
      }
      100% {
        opacity: 1;
        transform: scale(1.2);
      }
    }

    @keyframes glow-pulse {
      0%, 100% {
        box-shadow: 0 0 10px var(--accent-glow);
        opacity: 0.8;
      }
      50% {
        box-shadow: 0 0 20px var(--accent-glow);
        opacity: 1;
      }
    }

    .blog-post {
      background: var(--glass-bg);
      border: 1px solid var(--glass-border);
      border-radius: var(--card-radius);
      backdrop-filter: blur(20px);
      box-shadow: var(--glass-shadow);
      overflow: hidden;
      position: relative;
      flex: 1;
      order: 2;
      max-width: 800px;
    }

    .blog-post::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 1px;
      background: linear-gradient(90deg, transparent, var(--accent-glow), transparent);
      opacity: 0.6;
    }

    .blog-header {
      text-align: center;
      padding: 2rem 2rem 0;
      background: transparent;
      border-bottom: none;
      position: relative;
    }

    .blog-header-content {
      position: relative;
      z-index: 2;
      margin-bottom: 2rem;
    }

    .classification-tag {
      display: inline-block;
      background: var(--accent);
      color: white;
      padding: 0.5rem 1rem;
      border-radius: 15px;
      font-size: 0.75rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      margin-bottom: 1.5rem;
      font-family: 'Montserrat', sans-serif;
    }

    .blog-title {
      font-family: 'Sora', sans-serif;
      font-size: clamp(1.8rem, 4vw, 2.5rem);
      font-weight: 700;
      line-height: 1.2;
      margin: 0 2rem 1.5rem 2rem;
      color: white;
      text-shadow: none;
    }

    .blog-meta {
      display: flex;
      justify-content: center;
      align-items: center;
      gap: 2rem;
      font-family: 'Sora', sans-serif;
      font-size: 0.9rem;
      color: var(--text-secondary);
      margin-bottom: 0;
    }

    .meta-item {
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }

    .publish-date {
      font-weight: 400;
      color: var(--text-secondary);
    }

    .reading-time {
      font-weight: 400;
      color: var(--text-secondary);
    }

    .header-image {
      margin: 2rem 0 0 0;
      border-radius: 12px;
      overflow: hidden;
      box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
    }

    .header-image img {
      width: 100%;
      height: auto;
      display: block;
      border-radius: 12px;
    }

    .blog-tags {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 0.5rem;
      margin: 1.5rem 0 0 0;
    }



    .blog-content {
      padding: 3rem;
      color: var(--text-secondary);
      line-height: 1.8;
      font-size: 1.1rem;
    }

    .blog-content :global(h2) {
      font-family: 'Sora', sans-serif;
      font-size: 1.8rem;
      font-weight: 600;
      color: var(--text-primary);
      margin: 2.5rem 0 1rem 0;
      padding-bottom: 0.5rem;
      border-bottom: 2px solid var(--glass-border);
      position: relative;
    }

    .blog-content :global(h2::after) {
      content: '';
      position: absolute;
      bottom: -2px;
      left: 0;
      width: 40px;
      height: 2px;
      background: var(--accent-glow);
    }

    .blog-content :global(h3) {
      font-family: 'Sora', sans-serif;
      font-size: 1.4rem;
      font-weight: 600;
      color: var(--text-primary);
      margin: 2rem 0 0.8rem 0;
    }

    .blog-content :global(p) {
      margin-bottom: 1.5rem;
      font-family: 'Nunito Sans', sans-serif;
    }

    .blog-content :global(blockquote) {
      background: var(--glass-bg);
      border-left: 4px solid var(--accent-glow);
      padding: 0.5rem 1rem;
      margin: 0.5rem 0;
      border-radius: 0 8px 8px 0;
      box-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);
      font-style: italic;
      font-size: 1.1rem;
      line-height: 1.4;
      font-family: 'Nunito Sans', sans-serif;
      color: var(--text-secondary);
    }

    .blog-content :global(code) {
      background: var(--glass-bg);
      border: 1px solid var(--glass-border);
      padding: 0.2rem 0.5rem;
      border-radius: 6px;
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.9em;
      color: var(--accent-glow);
    }

    .blog-content :global(pre) {
      background: var(--secondary-navy);
      border: 1px solid var(--glass-border);
      padding: 2rem;
      border-radius: 12px;
      margin: 2rem 0;
      overflow-x: auto;
      box-shadow: 0 8px 32px rgba(0, 0, 0, 0.5);
    }

    .blog-content :global(pre code) {
      background: none;
      border: none;
      padding: 0;
      color: var(--text-primary);
    }

    .blog-content :global(img) {
      border-radius: 12px;
      box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
      margin: 2rem 0;
      transition: transform 0.3s ease;
    }

    .blog-content :global(img:hover) {
      transform: scale(1.02);
    }

    @media (max-width: 1024px) {
      .table-of-contents {
        display: none;
      }

      .blog-container {
        max-width: 900px;
        flex-direction: column;
        gap: 0;
      }

      .blog-post {
        max-width: none;
        order: 2;
      }
    }

    @media (max-width: 768px) {
      .blog-container {
        padding: 1rem 0.5rem;
      }

      .blog-header {
        padding: 1.5rem 1rem 0;
      }

      .blog-meta {
        flex-direction: column;
        gap: 1rem;
      }

      .blog-content {
        padding: 2rem 1.5rem;
        font-size: 1rem;
      }

      .blog-title {
        font-size: clamp(1.8rem, 8vw, 2.5rem);
      }

      .blog-meta {
        font-size: 0.9rem;
      }

      .blog-content :global(h2) {
        font-size: 1.5rem;
      }

      .blog-content :global(h3) {
        font-size: 1.25rem;
      }
    }
  </style>

  <script>
    // Reading progress indicator
    function updateReadingProgress() {
      const article = document.querySelector('.blog-content');
      const progressBar = document.getElementById('reading-progress');
      
      if (!article || !progressBar) return;

      const articleTop = article.offsetTop;
      const articleHeight = article.offsetHeight;
      const windowHeight = window.innerHeight;
      const scrollTop = window.scrollY;
      
      const progress = Math.min(
        Math.max(
          (scrollTop - articleTop + windowHeight / 3) / articleHeight,
          0
        ),
        1
      );
      
      progressBar.style.width = `${progress * 100}%`;
    }

    // Table of Contents functionality
    function generateTableOfContents() {
      const tocList = document.getElementById('toc-list');
      const tocContainer = document.getElementById('table-of-contents');
      const headings = document.querySelectorAll('.blog-content h2, .blog-content h3, .blog-content h4');
      
      if (!tocList || !headings.length) {
        if (tocContainer) tocContainer.style.display = 'none';
        return;
      }

      // Clear existing TOC
      tocList.innerHTML = '';

      headings.forEach((heading, index) => {
        // Create ID if it doesn't exist
        if (!heading.id) {
          heading.id = `heading-${index}`;
        }

        const li = document.createElement('li');
        const a = document.createElement('a');
        a.href = `#${heading.id}`;
        a.textContent = heading.textContent;
        a.className = `toc-${heading.tagName.toLowerCase()}`;
        
        li.appendChild(a);
        tocList.appendChild(li);

        // Smooth scroll with offset
        a.addEventListener('click', (e) => {
          e.preventDefault();
          const headerOffset = 100; // Adjust this value for desired spacing
          const elementPosition = heading.offsetTop;
          const offsetPosition = elementPosition - headerOffset;
          
          window.scrollTo({
            top: offsetPosition,
            behavior: 'smooth'
          });
        });
      });
    }

    // Update active TOC item based on scroll position
    function updateActiveTocItem() {
      const headings = document.querySelectorAll('.blog-content h2, .blog-content h3, .blog-content h4');
      const tocLinks = document.querySelectorAll('.toc-list a');
      
      if (!headings.length || !tocLinks.length) return;

      const scrollTop = window.scrollY + 100; // Offset for better UX
      let activeHeading = null;

      // Find the current heading
      headings.forEach((heading) => {
        if (heading.offsetTop <= scrollTop) {
          activeHeading = heading;
        }
      });

      // Update active state
      tocLinks.forEach((link) => {
        link.classList.remove('active');
        if (activeHeading && link.getAttribute('href') === `#${activeHeading.id}`) {
          link.classList.add('active');
        }
      });
    }

    // Throttled scroll handler
    let ticking = false;
    function onScroll() {
      if (!ticking) {
        requestAnimationFrame(() => {
          updateReadingProgress();
          updateActiveTocItem();
          ticking = false;
        });
        ticking = true;
      }
    }

    // Initialize
    document.addEventListener('DOMContentLoaded', () => {
      generateTableOfContents();
      updateReadingProgress();
      updateActiveTocItem();
    });
    
    window.addEventListener('scroll', onScroll);
    window.addEventListener('resize', updateReadingProgress);
  </script>
</BaseLayout>
