								<path d="M150.822 194.648c-2.036 3.491-6.545 5.139-10.035 3.685-3.491-1.406-4.558-5.333-2.57-8.727 2.036-3.393 6.351-5.042 9.793-3.684 3.491 1.26 4.751 5.187 2.812 8.726m-18.568 23.756c-5.624 8.968-17.695 12.895-26.761 8.774-8.92-4.072-11.587-14.495-5.963-23.27 5.575-8.727 17.21-12.605 26.228-8.823 9.114 3.926 12.023 14.253 6.496 23.319m21.138-63.51c-27.683-7.223-58.952 6.594-70.976 30.979-12.265 24.871-.387 52.504 27.537 61.522 28.991 9.356 63.121-4.994 74.999-31.803 11.732-26.277-2.909-53.28-31.56-60.698" fill="currentColor"></path>
							</g>
						</g>
					</svg>
				</a>
				</div>
			</div>
		</div>
		<div class="hero-visual">
			<div class="avatar-container">
				<div class="eclipse-effect"></div>
				<Image src={avatar} alt="Ellinia Fairy" class="avatar-image" width={240} height={290} />
			</div>
			<div class="map-container">
				<iframe 
					src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d9804334.4!2d139.75446034853152!3d35.54828459292251!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zMzXCsDMyJzUzLjgiTiAxMznCsDQ1JzE2LjEiRQ!5e0!3m2!1sen!2sjp!4v1"
					class="google-map"
					allowfullscreen=""
					loading="lazy"
					referrerpolicy="no-referrer-when-downgrade">
				</iframe>
			</div>
		</div>
	</div>
</BaseLayout>

<style>
.hero-content {
	display: grid;
	grid-template-columns: 1fr 1fr;
	gap: 4rem;
	max-width: 1200px;
	width: 100%;
	margin: 0 auto;
	padding: 4rem 2rem;
	align-items: center;
	position: relative;
}

.hero-text {
	padding: 2rem 0;
}

.hero-title {
	font-family: 'Sora', sans-serif;
	font-size: clamp(2rem, 4vw, 3.5rem);
	font-weight: 800;
	line-height: 1.1;
	margin-bottom: 1.5rem;
	color: var(--text-primary);
}

.sparkle {
	display: inline-block;
	animation: sparkleRotate 3s ease-in-out infinite;
	filter: none;
}

.hero-intro {
	font-family: 'Inter', sans-serif;
	font-size: 1.1rem;
	line-height: 1.7;
	color: var(--text-secondary);
	margin-top: 1.5rem;
}

.hero-intro p {
	margin-bottom: 1.2rem;
}

.hero-intro strong {
	color: var(--text-primary);
	font-weight: 600;
}

.find-more-btn {
	display: inline-flex;
	align-items: center;
	gap: 0.5rem;
	background: linear-gradient(135deg, var(--accent) 0%, var(--accent-glow) 100%);
	color: white;
	padding: 1.2rem 2.5rem;
	border-radius: 30px;
	text-decoration: none;
	font-weight: 600;
	font-size: 1.1rem;
	font-family: 'Montserrat', sans-serif;
	transition: all 0.3s ease;
	box-shadow: 
		0 8px 20px rgba(41, 98, 255, 0.3),
		0 0 0 1px rgba(255, 255, 255, 0.1);
	position: relative;
	overflow: hidden;
}

.find-more-btn:hover {
	transform: translateY(-2px);
	box-shadow: 
		0 12px 30px rgba(41, 98, 255, 0.4),
		0 0 40px rgba(34, 211, 238, 0.3);
}

.find-more-btn svg {
	transition: transform 0.3s ease;
}

.find-more-btn:hover svg {
	transform: translate(2px, -2px);
}

.action-section {
	display: flex;
	align-items: center;
	justify-content: flex-start;
	gap: 2.5rem;
	margin-top: 3rem;
}

.social-links {
	display: flex;
	gap: 0.8rem;
}

.social-link {
	color: var(--text-secondary);
	transition: all 0.3s ease;
	padding: 0.8rem;
	border-radius: 50%;
	background: rgba(255, 255, 255, 0.05);
	border: 1px solid rgba(255, 255, 255, 0.1);
	display: flex;
	align-items: center;
	justify-content: center;
}

.social-link:hover {
	color: var(--accent-glow);
	transform: translateY(-2px);
	box-shadow: 0 8px 20px rgba(0, 255, 255, 0.3);
	background: rgba(0, 255, 255, 0.1);
}

.sr-only {
	position: absolute;
	width: 1px;
	height: 1px;
	padding: 0;
	margin: -1px;
	overflow: hidden;
	clip: rect(0, 0, 0, 0);
	white-space: nowrap;
	border: 0;
}

.hero-visual {
	position: relative;
	height: 100%;
	display: flex;
	align-items: center;
	justify-content: center;
	gap: 4rem;
}

.avatar-container {
	position: relative;
	width: 250px;
	height: 300px;
	display: flex;
	align-items: center;
	justify-content: center;
}

.eclipse-effect {
	position: absolute;
	width: 100%;
	height: 100%;
	border-radius: 50%;
	background: radial-gradient(circle at 30% 30%, 
		rgba(0, 255, 255, 0.4) 0%,
		rgba(138, 43, 226, 0.3) 40%,
		rgba(255, 0, 255, 0.2) 70%,
		transparent 100%
	);
	animation: eclipsePulse 4s ease-in-out infinite;
	z-index: 1;
}

.eclipse-effect::before {
	content: '';
	position: absolute;
	top: -10px;
	left: -10px;
	right: -10px;
	bottom: -10px;
	border-radius: 50%;
	background: linear-gradient(45deg, 
		rgba(0, 255, 255, 0.1) 0%,
		transparent 30%,
		transparent 70%,
		rgba(255, 0, 255, 0.1) 100%
	);
	animation: eclipseRotate 6s linear infinite;
}

.avatar-image {
	width: 240px;
	height: 290px;
	border-radius: 50%;
	object-fit: cover;
	border: 3px solid rgba(255, 255, 255, 0.1);
	box-shadow: 
		0 0 30px rgba(0, 255, 255, 0.3),
		0 0 60px rgba(138, 43, 226, 0.2),
		inset 0 0 30px rgba(255, 255, 255, 0.05);
	z-index: 2;
	position: relative;
	transition: transform 0.3s ease;
}


.map-container {
	position: relative;
	width: 270px;
	height: 270px;
	border-radius: 50%;
	overflow: hidden;
	border: 3px solid rgba(255, 255, 255, 0.1);
	box-shadow: 
		0 0 30px rgba(34, 197, 94, 0.4),
		0 0 60px rgba(22, 163, 74, 0.3),
		0 0 90px rgba(16, 185, 129, 0.2),
		inset 0 0 30px rgba(134, 239, 172, 0.05);
	transition: transform 0.3s ease;
}




.google-map {
	width: 100%;
	height: 100%;
	border: none;
	filter: contrast(1.1) brightness(0.9) hue-rotate(15deg);
}

@keyframes backgroundPulse {
	0%, 100% { opacity: 1; }
	50% { opacity: 0.8; }
}

@keyframes sparkleRotate {
	0%, 100% { transform: rotate(0deg) scale(1); }
	25% { transform: rotate(90deg) scale(1.1); }
	50% { transform: rotate(180deg) scale(1); }
	75% { transform: rotate(270deg) scale(1.1); }
}

@keyframes orbPulse {
	0%, 100% { 
		transform: scale(1);
		opacity: 0.8;
	}
	50% { 
		transform: scale(1.1);
		opacity: 1;
	}
}

@keyframes innerGlow {
	0%, 100% { 
		transform: translate(-50%, -50%) scale(1);
		opacity: 0.3;
	}
	50% { 
		transform: translate(-50%, -50%) scale(1.2);
		opacity: 0.6;
	}
}

@keyframes float {
	0%, 100% { 
		transform: translateY(0px) rotate(0deg);
		opacity: 0.8;
	}
	25% { 
		transform: translateY(-20px) rotate(90deg);
		opacity: 1;
	}
	50% { 
		transform: translateY(-10px) rotate(180deg);
		opacity: 0.6;
	}
	75% { 
		transform: translateY(-15px) rotate(270deg);
		opacity: 1;
	}
}

@media (max-width: 768px) {
	.hero-content {
		grid-template-columns: 1fr;
		gap: 2rem;
		text-align: center;
		padding: 0 1rem;
	}
	
	.hero-visual {
		height: 300px;
	}
	
	.magic-orb {
		width: 200px;
		height: 200px;
	}
	
	.magic-orb::before {
		width: 120px;
		height: 120px;
	}
	
	.element {
		font-size: 1.5rem;
	}
}


@media (max-width: 768px) {
	.hero-content {
		grid-template-columns: 1fr;
		gap: 2rem;
		text-align: center;
		padding: 0 1rem;
		max-width: 90vw;
	}
	
	.hero-section {
		height: 60vh;
	}
	
	.hero-visual {
		flex-direction: row;
		gap: 1.5rem;
	}
	
	.avatar-container {
		width: 200px;
		height: 200px;
	}
	
	.avatar-image {
		width: 180px;
		height: 180px;
	}
	
	.map-container {
		width: 200px;
		height: 200px;
	}
	
}
</style>

